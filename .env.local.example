# =============================================================================
# Takos Local Stack (Template)
# =============================================================================
# Copy this file to .env.local before running, or point TAKOS_LOCAL_ENV_FILE at another path:
#   pnpm local:up
# Direct docker compose usage must set both the env file flag and TAKOS_LOCAL_ENV_FILE:
#   TAKOS_LOCAL_ENV_FILE=/tmp/takos-local.env docker compose --env-file /tmp/takos-local.env -f compose.local.yml up --build
# Images are built from the monorepo Dockerfiles.
# This file is safe to publish; replace all placeholder credentials locally.
# =============================================================================

TAKOS_ADMIN_DOMAIN=admin.localhost
TAKOS_TENANT_BASE_DOMAIN=app.localhost

TAKOS_CONTROL_WEB_PORT=8787
TAKOS_CONTROL_DISPATCH_PORT=8788
TAKOS_RUNTIME_HOST_PORT=8789
TAKOS_EXECUTOR_HOST_PORT=8790
TAKOS_BROWSER_HOST_PORT=8791
TAKOS_CONTROL_WORKER_POLL_INTERVAL_MS=250
TAKOS_CONTROL_WORKER_SCHEDULED_INTERVAL_MS=60000
TAKOS_CONTROL_WORKER_HEARTBEAT_FILE=/var/lib/takos/control/worker-heartbeat.json
TAKOS_CONTROL_WORKER_HEARTBEAT_TTL_MS=120000

TAKOS_RUNTIME_PORT=8081
TAKOS_EXECUTOR_PORT=8082
TAKOS_BROWSER_PORT=8083
TAKOS_POSTGRES_PORT=15432
TAKOS_REDIS_PORT=16379
TAKOS_MINIO_PORT=19000
TAKOS_MINIO_CONSOLE_PORT=19001

TAKOS_LOCAL_DATA_DIR=/var/lib/takos/control
TAKOS_LOCAL_RUNTIME_URL=http://runtime:8080/
TAKOS_LOCAL_EXECUTOR_URL=http://executor:8080/
TAKOS_LOCAL_BROWSER_URL=http://browser:8080/
# Optional debug-only tenant runtime materialization.
# TAKOS_LOCAL_DEBUG_TENANT_RUNTIME=miniflare
TAKOS_OCI_ORCHESTRATOR_PORT=9002
OCI_ORCHESTRATOR_URL=http://oci-orchestrator:9002/
OCI_ORCHESTRATOR_DATA_DIR=/var/lib/takos/control/oci-orchestrator
# OCI_ORCHESTRATOR_TOKEN=replace-me
CONTROL_RPC_BASE_URL=http://executor-host:8790/

DATABASE_URL=postgresql://takos:takos@postgres:5432/takos
REDIS_URL=redis://redis:6379
TAKOS_ALLOW_NO_LLM=1

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=takos
S3_SECRET_ACCESS_KEY=takos-dev-secret
S3_BUCKET=takos-tenant-source

MINIO_ROOT_USER=takos
MINIO_ROOT_PASSWORD=takos-dev-secret

PLATFORM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
PLATFORM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# Optional Cloudflare deploy target configuration.
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# WFP_DISPATCH_NAMESPACE=
# CF_ZONE_ID=
