# =============================================================================
# Takos Local Stack (Template)
# =============================================================================
# Copy this file to .env.local before running, or point TAKOS_LOCAL_ENV_FILE at another path:
#   deno task local:up
# Direct docker compose usage must set both the env file flag and TAKOS_LOCAL_ENV_FILE:
#   TAKOS_LOCAL_ENV_FILE=/tmp/takos-local.env docker compose --env-file /tmp/takos-local.env -f compose.local.yml up --build
# Images are built from the monorepo Dockerfiles.
# This file is safe to publish; replace all placeholder credentials locally.
# =============================================================================

TAKOS_ADMIN_DOMAIN=admin.localhost
TAKOS_TENANT_BASE_DOMAIN=app.localhost

# Port defaults: canonical source is DEFAULT_LOCAL_PORTS in
# packages/control/src/local-platform/runtime-types.ts
TAKOS_CONTROL_WEB_PORT=8787
TAKOS_CONTROL_DISPATCH_PORT=8788
TAKOS_RUNTIME_HOST_PORT=8789
TAKOS_EXECUTOR_HOST_PORT=8790
TAKOS_CONTROL_WORKER_POLL_INTERVAL_MS=250
TAKOS_CONTROL_WORKER_SCHEDULED_INTERVAL_MS=60000
TAKOS_CONTROL_WORKER_HEARTBEAT_FILE=/var/lib/takos/control/worker-heartbeat.json
TAKOS_CONTROL_WORKER_HEARTBEAT_TTL_MS=120000

TAKOS_RUNTIME_PORT=8081
TAKOS_EXECUTOR_PORT=8082
TAKOS_POSTGRES_PORT=15432
TAKOS_REDIS_PORT=16379
TAKOS_MINIO_PORT=19000
TAKOS_MINIO_CONSOLE_PORT=19001

TAKOS_LOCAL_DATA_DIR=/var/lib/takos/control
# Infra host forwarding only. These URLs do not override tenant worker-bundle resolution.
TAKOS_LOCAL_RUNTIME_URL=http://runtime:8080/
TAKOS_LOCAL_EXECUTOR_URL=http://rust-agent:8080/
TAKOS_OCI_ORCHESTRATOR_PORT=9002
OCI_ORCHESTRATOR_URL=http://oci-orchestrator:9002/
OCI_ORCHESTRATOR_DATA_DIR=/var/lib/takos/control/oci-orchestrator
# OCI_ORCHESTRATOR_TOKEN=replace-me
CONTROL_RPC_BASE_URL=http://executor-host:8790/
EXECUTOR_PROXY_SECRET=replace-me
TAKOS_INTERNAL_API_SECRET=replace-me

DATABASE_URL=postgresql://takos:takos@postgres:5432/takos
REDIS_URL=redis://redis:6379
TAKOS_ALLOW_NO_LLM=1

AWS_REGION=us-east-1
AWS_S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=takos
AWS_SECRET_ACCESS_KEY=takos-dev-secret
AWS_S3_GIT_OBJECTS_BUCKET=takos-tenant-source
AWS_S3_OFFLOAD_BUCKET=takos-tenant-source
AWS_S3_TENANT_SOURCE_BUCKET=takos-tenant-source
AWS_S3_WORKER_BUNDLES_BUCKET=takos-tenant-source
AWS_S3_TENANT_BUILDS_BUCKET=takos-tenant-source

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=takos
S3_SECRET_ACCESS_KEY=takos-dev-secret
S3_BUCKET=takos-tenant-source

MINIO_ROOT_USER=takos
MINIO_ROOT_PASSWORD=takos-dev-secret

# Runtime-service JWTs are signed with PLATFORM_PRIVATE_KEY.
# Keep PLATFORM_PUBLIC_KEY and JWT_PUBLIC_KEY as the matching public key.
PLATFORM_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
PLATFORM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# Optional default app distribution override.
# Env JSON wins over DB-managed entries. Leave both JSON vars unset to use the
# internal DB save API or the fallback docs/excel/slide set.
# TAKOS_DEFAULT_APPS_PREINSTALL=true
# TAKOS_DEFAULT_APP_REPOSITORIES_JSON=[{"name":"takos-docs","url":"https://github.com/example/takos-docs.git"}]

# Optional Cloudflare deploy target configuration.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# WFP_DISPATCH_NAMESPACE=
# CF_ZONE_ID=

# Optional runtime-native container backends for the OCI orchestrator.
# ECS:
# AWS_REGION=us-east-1
# AWS_ECS_REGION=us-east-1
# AWS_ECS_CLUSTER_ARN=arn:aws:ecs:us-east-1:123456789012:cluster/takos
# AWS_ECS_TASK_DEFINITION_FAMILY=takos-worker
# AWS_ECS_SERVICE_ARN=arn:aws:ecs:us-east-1:123456789012:service/takos/web
# AWS_ECS_SERVICE_NAME=web
# AWS_ECS_CONTAINER_NAME=app
# AWS_ECS_SUBNET_IDS=subnet-aaa,subnet-bbb
# AWS_ECS_SECURITY_GROUP_IDS=sg-aaa
# AWS_ECS_ASSIGN_PUBLIC_IP=true
# AWS_ECS_LAUNCH_TYPE=FARGATE
# AWS_ECS_DESIRED_COUNT=1
# AWS_ECS_BASE_URL=https://web.example.com
# AWS_ECS_HEALTH_URL=https://web.example.com/health
#
# Cloud Run:
# GCP_PROJECT_ID=takos-project
# GCP_CLOUD_RUN_REGION=us-central1
# GCP_CLOUD_RUN_SERVICE_ID=takos-service
# GCP_CLOUD_RUN_SERVICE_ACCOUNT=takos-runtime@takos-project.iam.gserviceaccount.com
# GCP_CLOUD_RUN_INGRESS=all
# GCP_CLOUD_RUN_ALLOW_UNAUTHENTICATED=false
# GCP_CLOUD_RUN_BASE_URL=https://takos-service-uc.a.run.app
# GCP_CLOUD_RUN_DELETE_ON_REMOVE=true
