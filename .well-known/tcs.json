{
  "schemaVersion": "tcs.repo/v1",
  "id": "takos",
  "modulePath": "deploy/opentofu",
  "kind": "worker",
  "surface": "service",
  "provider": "cloudflare",
  "category": "workspace",
  "suggestedName": "takos",
  "name": {
    "ja": "Takos",
    "en": "Takos"
  },
  "description": {
    "ja": "AI workspace distribution を自分の環境に公開します。",
    "en": "Deploys the Takos AI workspace distribution."
  },
  "badge": {
    "ja": "追加候補",
    "en": "Installable"
  },
  "iconUrl": "web/public/logo.png",
  "inputs": [
    {
      "name": "project_name",
      "type": "string",
      "format": "text",
      "required": true,
      "defaultValue": "service-name-with-space",
      "label": {
        "ja": "サービス名",
        "en": "Service name"
      }
    },
    {
      "name": "public_subdomain",
      "type": "string",
      "format": "subdomain",
      "required": true,
      "defaultValue": "service-name-with-space",
      "label": {
        "ja": "公開サブドメイン",
        "en": "Public subdomain"
      }
    },
    {
      "name": "public_url",
      "type": "string",
      "format": "url",
      "required": true,
      "label": {
        "ja": "公開URL",
        "en": "Public URL"
      }
    },
    {
      "name": "takosumi_accounts_url",
      "type": "string",
      "format": "url",
      "advanced": true,
      "label": {
        "ja": "Accounts URL",
        "en": "Accounts URL"
      }
    },
    {
      "name": "takosumi_accounts_issuer_url",
      "type": "string",
      "format": "url",
      "advanced": true,
      "label": {
        "ja": "OIDC issuer",
        "en": "OIDC issuer"
      }
    },
    {
      "name": "takosumi_accounts_client_id",
      "type": "string",
      "advanced": true,
      "label": {
        "ja": "OIDC client ID",
        "en": "OIDC client ID"
      }
    },
    {
      "name": "takosumi_accounts_redirect_uri",
      "type": "string",
      "format": "url",
      "advanced": true,
      "label": {
        "ja": "OIDC redirect URI",
        "en": "OIDC redirect URI"
      }
    },
    {
      "name": "release_container_images",
      "type": "json",
      "advanced": true,
      "defaultValue": "{\"runtime\":\"registry.cloudflare.com/a10162d23653f1ad1193dabf520a5dd0/takos-worker-runtime:0.10.0-bfdd9f8bb79c\",\"executor\":\"registry.cloudflare.com/a10162d23653f1ad1193dabf520a5dd0/takos-agent-executor:0.10.0-bfdd9f8bb79c\"}",
      "label": {
        "ja": "Release container images",
        "en": "Release container images"
      },
      "helper": {
        "ja": "Git CI が公開した Takos release container image refs。通常は変更不要です。",
        "en": "Takos release container image refs published by Git CI. Usually leave unchanged."
      }
    }
  ],
  "installExperience": {
    "projections": [
      {
        "kind": "service_name",
        "variable": "project_name"
      },
      {
        "kind": "public_endpoint",
        "variables": {
          "subdomain": "public_subdomain",
          "url": "public_url"
        },
        "baseDomain": "app.takos.jp"
      },
      {
        "kind": "oidc_client",
        "variables": {
          "issuerUrl": "takosumi_accounts_issuer_url",
          "accountsUrl": "takosumi_accounts_url",
          "clientId": "takosumi_accounts_client_id",
          "redirectUri": "takosumi_accounts_redirect_uri"
        },
        "callbackPath": "/auth/oidc/callback"
      }
    ]
  },
  "outputAllowlist": [
    {
      "key": "launch_url",
      "from": "launch_url",
      "type": "url"
    },
    {
      "key": "url",
      "from": "url",
      "type": "url"
    },
    {
      "key": "public_url",
      "from": "public_url",
      "type": "url"
    },
    {
      "key": "app_deployment",
      "from": "app_deployment",
      "type": "json"
    },
    {
      "key": "takosumi_release",
      "from": "takosumi_release",
      "type": "json"
    }
  ]
}
