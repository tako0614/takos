# =============================================================================
# Takos Executor - Environment Variables
# =============================================================================
# Copy this file to .env when running takos-executor directly.
# In the Compose server stack these values are supplied by compose.
# =============================================================================

PORT=8080
NODE_ENV=development
# Port 8790 = DEFAULT_LOCAL_PORTS.executorHost in
# packages/control/src/local-platform/runtime-types.ts
CONTROL_RPC_BASE_URL=http://127.0.0.1:8790
TAKOS_ALLOW_NO_LLM=1
MAX_CONCURRENT_RUNS=5
SHUTDOWN_GRACE_MS=30000

# Optional model provider keys for actual agent execution.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
