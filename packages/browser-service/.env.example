# =============================================================================
# Takos Browser - Environment Variables
# =============================================================================
# Direct runs do not auto-load `.env`.
# Copy this file to `.env` and start with `pnpm start:env`, or export the vars
# in your shell before running `pnpm start`.
# In the Compose server stack these values are supplied by compose.
# =============================================================================

PORT=8080
NODE_ENV=development
SHUTDOWN_GRACE_MS=15000
