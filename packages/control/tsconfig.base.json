{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": "../..",
    "paths": {
      // All @/ paths resolve to packages/control/src/ subdirectories.
      // Keep in sync with apps/control/tsconfig.json (which uses baseUrl "."
      // and therefore prefixes all targets with "../../").

      // Broad directory aliases — map top-level src subdirs directly.
      "@/application/*": ["packages/control/src/application/*"],
      "@/infra/*": ["packages/control/src/infra/*"],
      "@/local-platform/*": ["packages/control/src/local-platform/*"],
      "@/platform/*": ["packages/control/src/platform/*"],
      "@/runtime/*": ["packages/control/src/runtime/*"],
      "@/server/*": ["packages/control/src/server/*"],
      "@/shared/*": ["packages/control/src/shared/*"],

      // Shortcut aliases — remap deep paths to convenient short prefixes.
      // These take priority over the broad aliases above when both match.
      "@/services/*": ["packages/control/src/application/services/*"],
      "@/routes/*": ["packages/control/src/server/routes/*"],
      "@/middleware/*": ["packages/control/src/server/middleware/*"],
      "@/tools/*": ["packages/control/src/application/tools/*"],
      "@/durable-objects/*": ["packages/control/src/runtime/durable-objects/*"],
      "@/queues/*": ["packages/control/src/runtime/queues/*"],
      "@/runner/*": ["packages/control/src/runtime/runner/*"],
      "@/worker/*": ["packages/control/src/runtime/worker/*"],
      "@/container-hosts/*": ["packages/control/src/runtime/container-hosts/*"],
      "@/indexer/*": ["packages/control/src/runtime/indexer/*"],
      "@/db": ["packages/control/src/infra/db/index.ts"],
      "@/db/*": ["packages/control/src/infra/db/*"],
      "@/types": ["packages/control/src/shared/types/index.ts"],
      "@/types/*": ["packages/control/src/shared/types/*"],
      "@/utils": ["packages/control/src/shared/utils/index.ts"],
      "@/utils/*": ["packages/control/src/shared/utils/*"],

      // Workspace package aliases
      "takos-actions-engine": ["packages/actions-engine/src/index.ts"],
      "takos-actions-engine/*": ["packages/actions-engine/src/*"],
      "takos-common": ["packages/common/src/index.ts"],
      "takos-common/*": ["packages/common/src/*"]
    }
  }
}
