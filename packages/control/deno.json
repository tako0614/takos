  "lint": {
    "exclude": [
      "src/**/__tests__/**",
      "src/**/*.test.ts",
      "src/**/*.test.tsx",
      "src/**/test/**"
    ],
    "rules": {
      "exclude": [
        "no-explicit-any",
        "no-import-prefix",
        "no-process-global",
        "no-slow-types",
        "no-unversioned-import",
        "no-unsafe-finally",
        "require-await"
      ]
    }
  },
  "tasks": {
    "test": "deno test --allow-all src/",
    "test:coverage": "deno test --allow-all --coverage src/"
  }
}
