{
  "@context": "https://takos.dev/contexts/deploy-v2.jsonld",
  "@id": "https://takos.dev/contracts/composite/web-app-with-cdn/v1",
  "@type": "CompositeContractDescriptor",
  "shortRef": "composite.web-app-with-cdn@v1",
  "domain": "composite",
  "lifecycleDomain": "revisioned-runtime",
  "changeEffect": "app-release",
  "description": "Web app fronted by a CDN with an asset object-store bucket. Expands into a runtime.js-worker@v1 component plus a resource.object-store.s3@v1 (binding env ASSETS_BUCKET) plus a publication.http-endpoint@v1 + interface.http@v1 route.",
  "expandsTo": [
    "runtime.js-worker@v1",
    "resource.object-store.s3@v1",
    "publication.http-endpoint@v1",
    "interface.http@v1"
  ],
  "invariants": [
    "expansion-before-plan",
    "descriptor-digest-pinned",
    "no-provider-semantics"
  ]
}
