{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "environment": "production",
  "profile": "@takosumi/plugins/profiles/gcp",
  "providerProfile": {
    "bundle": "@takosumi/plugins",
    "profileId": "operator.takosumi.gcp",
    "pluginIds": ["operator.takosumi.gcp"]
  },
  "artifacts": [
    {
      "kind": "terraform",
      "ref": "deploy/terraform/environments/gcp-prod"
    },
    {
      "kind": "helm",
      "ref": "deploy/helm/takos/values-gcp.yaml"
    }
  ],
  "providerProof": {
    "readOnlySmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=gcp TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/gcp.shape-v1.json deno task live-provisioning-smoke",
    "provisioningSmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=gcp TAKOSUMI_PLUGIN_LIVE_PROOF_MODE=live TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/gcp.shape-v1.json deno task live-provisioning-smoke",
    "cleanupTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=gcp TAKOSUMI_PLUGIN_LIVE_PROOF_MODE=live TAKOSUMI_PLUGIN_LIVE_CLEANUP_ONLY=1 TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/gcp.shape-v1.json deno task live-provisioning-smoke",
    "fixturePath": "../takosumi/fixtures/live-provisioning/gcp.shape-v1.json",
    "liveEnvPrefix": "TAKOSUMI_PLUGIN_GCP"
  },
  "requiredBindings": [
    {
      "kind": "gcp-service-account",
      "name": "takos-provider"
    },
    {
      "kind": "gcp-vpc",
      "name": "takos-vpc"
    }
  ],
  "target": {
    "id": "gcp",
    "projectId": "takos-prod",
    "region": "asia-northeast1",
    "clusterName": "takos-gke",
    "loadBalancerName": "takos-lb",
    "cloudDnsZone": "takos-zone",
    "metadata": {
      "providerBundle": "@takosumi/plugins",
      "terraform": "deploy/terraform/environments/gcp-prod",
      "helmOverlay": "deploy/helm/takos/values-gcp.yaml"
    }
  },
  "routing": {
    "publicBaseUrl": "https://takos.example.com",
    "adminBaseUrl": "https://admin.takos.example.com",
    "wildcardDomain": "*.app.takos.example.com",
    "dnsProvider": "gcp"
  },
  "services": [
    {
      "serviceId": "takos-app",
      "runtime": "container",
      "hostingTargetId": "gcp",
      "image": "ghcr.io/takos/takos-app:latest",
      "internalUrl": "http://takos-app.takos-system.svc.cluster.local:8080",
      "publicUrl": "https://admin.takos.example.com",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-app"
        }
      }
    },
    {
      "serviceId": "takosumi",
      "runtime": "container",
      "hostingTargetId": "gcp",
      "image": "ghcr.io/takos/takosumi:latest",
      "internalUrl": "http://takosumi.takos-system.svc.cluster.local:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi"
        }
      }
    },
    {
      "serviceId": "takos-git",
      "runtime": "container",
      "hostingTargetId": "gcp",
      "image": "ghcr.io/takos/takos-git:latest",
      "internalUrl": "http://takos-git.takos-system.svc.cluster.local:8790",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-git"
        }
      }
    },
    {
      "serviceId": "takos-agent",
      "runtime": "container",
      "hostingTargetId": "gcp",
      "image": "ghcr.io/takos/takos-agent:latest",
      "internalUrl": "http://takos-agent.takos-system.svc.cluster.local:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-agent"
        }
      }
    }
  ],
  "metadata": {
    "official": true,
    "liveSmokeTask": "deno task distribution:smoke --manifest deploy/distributions/gcp.json",
    "providerSmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=gcp TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/gcp.shape-v1.json deno task live-provisioning-smoke"
  }
}
