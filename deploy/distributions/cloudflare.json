{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "environment": "production",
  "profile": "operator.takosumi.cloudflare",
  "artifacts": [
    {
      "kind": "opentofu",
      "ref": "deploy/opentofu/environments/cloudflare-prod"
    },
    {
      "kind": "wrangler",
      "ref": "deploy/cloudflare/wrangler.toml"
    }
  ],
  "providerProof": {
    "liveEnvPrefix": "TAKOSUMI_PROVIDER_CLOUDFLARE",
    "deployControlProofTask": "cd ../takosumi && bun run opentofu:live-local-proof"
  },
  "requiredBindings": [
    {
      "kind": "cloudflare-d1",
      "name": "DB"
    },
    {
      "kind": "cloudflare-queue",
      "name": "RUN_QUEUE"
    }
  ],
  "target": {
    "id": "cloudflare",
    "accountId": "cloudflare-account-id",
    "workerName": "takos",
    "dispatchNamespace": "takos-tenants",
    "zoneId": "cloudflare-zone-id",
    "metadata": {
      "runtimeAgent": "cloudflare-containers",
      "operatorProfile": "operator.takosumi.cloudflare"
    }
  },
  "routing": {
    "publicBaseUrl": "https://app.takos.example.com",
    "adminBaseUrl": "https://app.takos.example.com",
    "wildcardDomain": "*.app.takos.example.com",
    "dnsProvider": "cloudflare"
  },
  "featuredApps": {
    "entries": [
      {
        "name": "takos-office",
        "title": "Office",
        "repositoryUrl": "https://github.com/tako0614/takos-office.git",
        "ref": "v0.1.0",
        "refType": "tag",
        "preinstall": false
      },
      {
        "name": "takos-computer",
        "title": "Computer",
        "repositoryUrl": "https://github.com/tako0614/takos-computer.git",
        "ref": "v2.1.2",
        "refType": "tag",
        "preinstall": false
      },
      {
        "name": "yurucommu",
        "title": "Yurucommu",
        "repositoryUrl": "https://github.com/tako0614/yurucommu.git",
        "ref": "main",
        "refType": "branch",
        "modulePath": ".",
        "preinstall": false,
        "variables": {
          "enable_cloudflare_resources": true,
          "project_name": "yurucommu",
          "worker_name": "yurucommu"
        }
      },
      {
        "name": "yurumeet",
        "title": "Yurumeet",
        "repositoryUrl": "https://github.com/tako0614/yurumeet.git",
        "ref": "main",
        "refType": "branch",
        "modulePath": ".",
        "preinstall": false,
        "variables": {
          "enable_cloudflare_resources": true,
          "project_name": "yurumeet",
          "worker_name": "yurumeet"
        }
      },
      {
        "name": "road-to-me",
        "title": "Road to Me",
        "repositoryUrl": "https://github.com/tako0614/road-to-me.git",
        "ref": "v0.1.0",
        "refType": "tag",
        "preinstall": false
      }
    ],
    "environmentOverrides": {
      "local": {
        "preinstall": []
      },
      "staging": {
        "preinstall": []
      },
      "production": {
        "preinstall": []
      }
    }
  },
  "services": [
    {
      "serviceId": "takos-worker",
      "runtime": "worker",
      "hostingTargetId": "cloudflare",
      "artifactRef": "worker:takos-worker",
      "internalUrl": "https://takos-worker.internal.takos.example",
      "publicUrl": "https://admin.takos.example.com",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-worker"
        }
      }
    },
    {
      "serviceId": "takos-agent",
      "runtime": "container",
      "hostingTargetId": "cloudflare",
      "image": "ghcr.io/takos/takos-agent:latest",
      "internalUrl": "https://takos-agent.internal.takos.example",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-agent"
        }
      }
    }
  ],
  "shapeTopology": {
    "version": "takos.resource-shapes.v1",
    "resources": [
      {
        "name": "takos-worker",
        "shape": "EdgeWorker",
        "serviceId": "takos-worker",
        "purpose": "Takos product Worker and public workspace surface"
      },
      {
        "name": "workspace-control-db",
        "shape": "SQLDatabase",
        "purpose": "Workspace, account projection, and product control data"
      },
      {
        "name": "session-cache-state",
        "shape": "KVStore",
        "purpose": "Session, cache, and lightweight state bindings"
      },
      {
        "name": "workspace-objects",
        "shape": "ObjectBucket",
        "purpose": "Files, workspace objects, and Git object backing storage"
      },
      {
        "name": "agent-jobs",
        "shape": "Queue",
        "purpose": "Agent execution jobs and async runtime work"
      },
      {
        "name": "product-events",
        "shape": "Queue",
        "purpose": "Product events, workflows, and deployment work"
      },
      {
        "name": "takos-agent",
        "shape": "ContainerService",
        "serviceId": "takos-agent",
        "purpose": "Agent execution service"
      }
    ],
    "connections": [
      {
        "from": "takos-worker",
        "to": "workspace-control-db",
        "name": "DB",
        "permissions": ["connect"],
        "projection": "runtime_binding"
      },
      {
        "from": "takos-worker",
        "to": "session-cache-state",
        "name": "CACHE",
        "permissions": ["read", "write"],
        "projection": "runtime_binding"
      },
      {
        "from": "takos-worker",
        "to": "workspace-objects",
        "name": "OBJECTS",
        "permissions": ["read", "write"],
        "projection": "runtime_binding"
      },
      {
        "from": "takos-worker",
        "to": "agent-jobs",
        "name": "RUN_QUEUE",
        "permissions": ["publish", "consume"],
        "projection": "runtime_binding"
      },
      {
        "from": "takos-worker",
        "to": "product-events",
        "name": "EVENT_QUEUE",
        "permissions": ["publish", "consume"],
        "projection": "runtime_binding"
      },
      {
        "from": "takos-worker",
        "to": "takos-agent",
        "name": "TAKOS_AGENT_INTERNAL_URL",
        "permissions": ["connect"],
        "projection": "internal_url"
      }
    ]
  },
  "metadata": {
    "official": true,
    "releaseGateTask": "bun run release-gate"
  },
  "operatorProfile": {
    "distribution": "takos",
    "profileId": "operator.takosumi.cloudflare",
    "implementationIds": ["operator.takosumi.cloudflare"]
  }
}
