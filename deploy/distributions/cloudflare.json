{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "environment": "production",
  "profile": "@takosumi/plugins/profiles/cloudflare",
  "providerProfile": {
    "bundle": "@takosumi/plugins",
    "profileId": "operator.takosumi.cloudflare",
    "pluginIds": [
      "operator.takosumi.cloudflare"
    ]
  },
  "artifacts": [
    {
      "kind": "wrangler",
      "ref": "../takosumi/deploy/cloudflare/wrangler.toml"
    },
    {
      "kind": "operator",
      "ref": "../takosumi/deploy/cloudflare"
    }
  ],
  "providerProof": {
    "readOnlySmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=cloudflare TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/cloudflare.shape-v1.json deno task live-provisioning-smoke",
    "provisioningSmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=cloudflare TAKOSUMI_PLUGIN_LIVE_PROOF_MODE=live TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/cloudflare.shape-v1.json deno task live-provisioning-smoke",
    "cleanupTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=cloudflare TAKOSUMI_PLUGIN_LIVE_PROOF_MODE=live TAKOSUMI_PLUGIN_LIVE_CLEANUP_ONLY=1 TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/cloudflare.shape-v1.json deno task live-provisioning-smoke",
    "fixturePath": "../takosumi/fixtures/live-provisioning/cloudflare.shape-v1.json",
    "liveEnvPrefix": "TAKOSUMI_PLUGIN_CLOUDFLARE"
  },
  "requiredBindings": [
    {
      "kind": "cloudflare-d1",
      "name": "TAKOS_DB"
    },
    {
      "kind": "cloudflare-r2",
      "name": "TAKOS_OBJECTS"
    },
    {
      "kind": "cloudflare-queue",
      "name": "TAKOS_QUEUE"
    },
    {
      "kind": "cloudflare-durable-object",
      "name": "TAKOS_COORDINATION"
    }
  ],
  "target": {
    "id": "cloudflare",
    "accountId": "cloudflare-account-id",
    "workerName": "takos",
    "dispatchNamespace": "takos-tenants",
    "zoneId": "cloudflare-zone-id",
    "metadata": {
      "providerBundle": "@takosumi/plugins",
      "paasRuntimeAgent": "cloudflare-containers"
    }
  },
  "routing": {
    "publicBaseUrl": "https://takos.example.com",
    "adminBaseUrl": "https://admin.takos.example.com",
    "accountsBaseUrl": "https://accounts.takos.example.com",
    "wildcardDomain": "*.app.takos.example.com",
    "dnsProvider": "cloudflare"
  },
  "defaultApps": {
    "entries": [
      {
        "name": "takos-docs",
        "title": "Docs",
        "repositoryUrl": "https://github.com/tako0614/takos-docs.git",
        "ref": "v0.1.1",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-excel",
        "title": "Excel",
        "repositoryUrl": "https://github.com/tako0614/takos-excel.git",
        "ref": "v0.1.1",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-slide",
        "title": "Slide",
        "repositoryUrl": "https://github.com/tako0614/takos-slide.git",
        "ref": "v0.1.1",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-computer",
        "title": "Computer",
        "repositoryUrl": "https://github.com/tako0614/takos-computer.git",
        "ref": "v2.1.1",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "yurucommu",
        "title": "Yurucommu",
        "repositoryUrl": "https://github.com/tako0614/yurucommu.git",
        "ref": "v1.2.2",
        "refType": "tag",
        "preinstall": true
      }
    ],
    "environmentOverrides": {
      "local": {
        "preinstall": []
      },
      "staging": {
        "preinstall": [
          "takos-docs",
          "takos-excel",
          "takos-slide",
          "takos-computer",
          "yurucommu"
        ]
      },
      "production": {
        "preinstall": [
          "takos-docs",
          "takos-excel",
          "takos-slide",
          "takos-computer",
          "yurucommu"
        ]
      }
    }
  },
  "services": [
    {
      "serviceId": "takos-app",
      "runtime": "worker",
      "hostingTargetId": "cloudflare",
      "artifactRef": "worker:takos-app",
      "internalUrl": "https://takos-app.internal.takos.example",
      "publicUrl": "https://admin.takos.example.com",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-app"
        }
      }
    },
    {
      "serviceId": "takosumi",
      "runtime": "worker",
      "hostingTargetId": "cloudflare",
      "artifactRef": "worker:takosumi",
      "internalUrl": "https://takosumi.internal.takos.example",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi"
        }
      }
    },
    {
      "serviceId": "takosumi-cloud",
      "runtime": "container",
      "hostingTargetId": "cloudflare",
      "image": "ghcr.io/takos/takosumi-cloud-accounts:latest",
      "internalUrl": "https://takosumi-cloud.internal.takos.example",
      "publicUrl": "https://accounts.takos.example.com",
      "smoke": {
        "healthPath": "/healthz",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi-cloud"
        }
      }
    },
    {
      "serviceId": "takos-git",
      "runtime": "container",
      "hostingTargetId": "cloudflare",
      "image": "ghcr.io/takos/takos-git:latest",
      "internalUrl": "https://takos-git.internal.takos.example",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-git"
        }
      }
    },
    {
      "serviceId": "takos-agent",
      "runtime": "container",
      "hostingTargetId": "cloudflare",
      "image": "ghcr.io/takos/takos-agent:latest",
      "internalUrl": "https://takos-agent.internal.takos.example",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-agent"
        }
      }
    }
  ],
  "metadata": {
    "official": true,
    "liveSmokeTask": "deno task distribution:smoke --manifest deploy/distributions/cloudflare.json",
    "providerSmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=cloudflare TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/cloudflare.shape-v1.json deno task live-provisioning-smoke"
  }
}
