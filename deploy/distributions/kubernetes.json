{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "environment": "production",
  "profile": "operator.takosumi.kubernetes",
  "artifacts": [
    {
      "kind": "helm",
      "ref": "deploy/helm/takos"
    }
  ],
  "providerProof": {
    "liveEnvPrefix": "TAKOSUMI_PROVIDER_KUBERNETES",
    "deployControlProofTask": "cd ../takosumi && bun run opentofu:live-local-proof"
  },
  "requiredBindings": [
    {
      "kind": "kubernetes-namespace",
      "name": "takos-system"
    },
    {
      "kind": "kubernetes-ingress-class",
      "name": "nginx"
    }
  ],
  "target": {
    "id": "kubernetes",
    "namespace": "takos-system",
    "clusterName": "takos-k8s",
    "context": "takos-production",
    "ingressClass": "nginx",
    "metadata": {
      "helmChart": "deploy/helm/takos",
      "operatorProfile": "operator.takosumi.kubernetes"
    }
  },
  "routing": {
    "publicBaseUrl": "https://takos.example.com",
    "adminBaseUrl": "https://admin.takos.example.com",
    "accountsBaseUrl": "https://accounts.takos.example.com",
    "wildcardDomain": "*.app.takos.example.com",
    "dnsProvider": "external"
  },
  "defaultApps": {
    "entries": [
      {
        "name": "takos-docs",
        "title": "Docs",
        "repositoryUrl": "https://github.com/tako0614/takos-docs.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-excel",
        "title": "Excel",
        "repositoryUrl": "https://github.com/tako0614/takos-excel.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-slide",
        "title": "Slide",
        "repositoryUrl": "https://github.com/tako0614/takos-slide.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-computer",
        "title": "Computer",
        "repositoryUrl": "https://github.com/tako0614/takos-computer.git",
        "ref": "v2.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "yurucommu",
        "title": "Yurucommu",
        "repositoryUrl": "https://github.com/tako0614/yurucommu.git",
        "ref": "v1.2.6",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "road-to-me",
        "title": "Road to Me",
        "repositoryUrl": "https://github.com/tako0614/road-to-me.git",
        "ref": "v0.1.0",
        "refType": "tag",
        "preinstall": false
      }
    ],
    "environmentOverrides": {
      "local": {
        "preinstall": []
      },
      "staging": {
        "preinstall": [
          "takos-docs",
          "takos-excel",
          "takos-slide",
          "takos-computer",
          "yurucommu"
        ]
      },
      "production": {
        "preinstall": [
          "takos-docs",
          "takos-excel",
          "takos-slide",
          "takos-computer",
          "yurucommu"
        ]
      }
    }
  },
  "services": [
    {
      "serviceId": "takos-worker",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takos-worker:latest",
      "internalUrl": "http://takos-worker.takos-system.svc.cluster.local:8080",
      "publicUrl": "https://admin.takos.example.com",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-worker"
        }
      }
    },
    {
      "serviceId": "takosumi",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takosumi:latest",
      "internalUrl": "http://takosumi.takos-system.svc.cluster.local:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi"
        }
      }
    },
    {
      "serviceId": "takosumi-accounts",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takosumi-accounts:latest",
      "internalUrl": "http://takosumi-accounts.takos-system.svc.cluster.local:8787",
      "publicUrl": "https://accounts.takos.example.com",
      "smoke": {
        "healthPath": "/healthz",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi-accounts"
        }
      }
    },
    {
      "serviceId": "takos-git",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takos-git:latest",
      "internalUrl": "http://takos-git.takos-system.svc.cluster.local:8790",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-git"
        }
      }
    },
    {
      "serviceId": "takos-agent",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takos-agent:latest",
      "internalUrl": "http://takos-agent.takos-system.svc.cluster.local:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-agent"
        }
      }
    }
  ],
  "metadata": {
    "official": true,
    "liveSmokeTask": "bun run distribution:smoke --manifest deploy/distributions/kubernetes.json"
  },
  "operatorProfile": {
    "distribution": "takosumi",
    "profileId": "operator.takosumi.kubernetes",
    "implementationIds": [
      "operator.takosumi.kubernetes"
    ]
  }
}
