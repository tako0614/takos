{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "environment": "production",
  "profile": "@takosumi/plugins/profiles/kubernetes",
  "providerProfile": {
    "bundle": "@takosumi/plugins",
    "profileId": "operator.takosumi.kubernetes",
    "pluginIds": [
      "operator.takosumi.kubernetes"
    ]
  },
  "artifacts": [
    {
      "kind": "helm",
      "ref": "deploy/helm/takos"
    }
  ],
  "providerProof": {
    "readOnlySmokeTask": "cd ../../takosumi && deno task live-smoke:k8s",
    "provisioningSmokeTask": "cd ../../takosumi && deno task live-provisioning-smoke:kubernetes",
    "cleanupTask": "cd ../../takosumi && deno task live-provisioning-cleanup:kubernetes",
    "fixturePath": "../../takosumi/fixtures/live-provisioning/kubernetes.json",
    "liveEnvPrefix": "TAKOSUMI_PLUGIN_KUBERNETES"
  },
  "requiredBindings": [
    {
      "kind": "kubernetes-namespace",
      "name": "takos-system"
    },
    {
      "kind": "kubernetes-ingress-class",
      "name": "nginx"
    }
  ],
  "target": {
    "id": "kubernetes",
    "namespace": "takos-system",
    "clusterName": "takos-k8s",
    "context": "takos-production",
    "ingressClass": "nginx",
    "metadata": {
      "providerBundle": "@takosumi/plugins",
      "helmChart": "deploy/helm/takos"
    }
  },
  "routing": {
    "publicBaseUrl": "https://takos.example.com",
    "adminBaseUrl": "https://admin.takos.example.com",
    "wildcardDomain": "*.app.takos.example.com",
    "dnsProvider": "external"
  },
  "services": [
    {
      "serviceId": "takos-app",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takos-app:latest",
      "internalUrl": "http://takos-app.takos-system.svc.cluster.local:8080",
      "publicUrl": "https://admin.takos.example.com",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-app"
        }
      }
    },
    {
      "serviceId": "takosumi",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takosumi:latest",
      "internalUrl": "http://takosumi.takos-system.svc.cluster.local:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi"
        }
      }
    },
    {
      "serviceId": "takos-git",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takos-git:latest",
      "internalUrl": "http://takos-git.takos-system.svc.cluster.local:8790",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-git"
        }
      }
    },
    {
      "serviceId": "takos-agent",
      "runtime": "kubernetes-deployment",
      "hostingTargetId": "kubernetes",
      "image": "ghcr.io/takos/takos-agent:latest",
      "internalUrl": "http://takos-agent.takos-system.svc.cluster.local:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-agent"
        }
      }
    }
  ],
  "metadata": {
    "official": true,
    "liveSmokeTask": "deno task distribution:smoke --manifest deploy/distributions/kubernetes.json",
    "providerSmokeTask": "cd ../../takosumi && deno task live-smoke:k8s"
  }
}
