{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "environment": "production",
  "profile": "@takos/takosumi-plugins/profiles/aws",
  "providerProfile": {
    "bundle": "@takos/takosumi-plugins",
    "profileId": "operator.takosumi.aws",
    "pluginIds": [
      "operator.takosumi.aws"
    ]
  },
  "artifacts": [
    {
      "kind": "terraform",
      "ref": "deploy/terraform/environments/aws-prod"
    },
    {
      "kind": "helm",
      "ref": "deploy/helm/takos/values-aws.yaml"
    }
  ],
  "providerProof": {
    "readOnlySmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=aws TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/aws.shape-v1.json bun run live-provisioning-smoke",
    "provisioningSmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=aws TAKOSUMI_PLUGIN_LIVE_PROOF_MODE=live TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/aws.shape-v1.json bun run live-provisioning-smoke",
    "cleanupTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=aws TAKOSUMI_PLUGIN_LIVE_PROOF_MODE=live TAKOSUMI_PLUGIN_LIVE_CLEANUP_ONLY=1 TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/aws.shape-v1.json bun run live-provisioning-smoke",
    "fixturePath": "../takosumi/fixtures/live-provisioning/aws.shape-v1.json",
    "liveEnvPrefix": "TAKOSUMI_PLUGIN_AWS"
  },
  "requiredBindings": [
    {
      "kind": "aws-iam-role",
      "name": "takos-provider"
    },
    {
      "kind": "aws-vpc",
      "name": "takos-vpc"
    }
  ],
  "target": {
    "id": "aws",
    "accountId": "123456789012",
    "region": "ap-northeast-1",
    "clusterName": "takos-eks",
    "loadBalancerName": "takos-alb",
    "route53ZoneId": "Z00000000000000000000",
    "metadata": {
      "providerBundle": "@takos/takosumi-plugins",
      "terraform": "deploy/terraform/environments/aws-prod",
      "helmOverlay": "deploy/helm/takos/values-aws.yaml"
    }
  },
  "routing": {
    "publicBaseUrl": "https://takos.example.com",
    "adminBaseUrl": "https://admin.takos.example.com",
    "accountsBaseUrl": "https://accounts.takos.example.com",
    "wildcardDomain": "*.app.takos.example.com",
    "dnsProvider": "aws"
  },
  "defaultApps": {
    "entries": [
      {
        "name": "takos-docs",
        "title": "Docs",
        "repositoryUrl": "https://github.com/tako0614/takos-docs.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-excel",
        "title": "Excel",
        "repositoryUrl": "https://github.com/tako0614/takos-excel.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-slide",
        "title": "Slide",
        "repositoryUrl": "https://github.com/tako0614/takos-slide.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-computer",
        "title": "Computer",
        "repositoryUrl": "https://github.com/tako0614/takos-computer.git",
        "ref": "v2.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "yurucommu",
        "title": "Yurucommu",
        "repositoryUrl": "https://github.com/tako0614/yurucommu.git",
        "ref": "v1.2.6",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "road-to-me",
        "title": "Road to Me",
        "repositoryUrl": "https://github.com/tako0614/road-to-me.git",
        "ref": "v0.1.0",
        "refType": "tag",
        "preinstall": false
      }
    ],
    "environmentOverrides": {
      "local": {
        "preinstall": []
      },
      "staging": {
        "preinstall": [
          "takos-docs",
          "takos-excel",
          "takos-slide",
          "takos-computer",
          "yurucommu"
        ]
      },
      "production": {
        "preinstall": [
          "takos-docs",
          "takos-excel",
          "takos-slide",
          "takos-computer",
          "yurucommu"
        ]
      }
    }
  },
  "services": [
    {
      "serviceId": "takos-worker",
      "runtime": "container",
      "hostingTargetId": "aws",
      "image": "ghcr.io/takos/takos-worker:latest",
      "internalUrl": "http://takos-worker.takos-system.svc.cluster.local:8080",
      "publicUrl": "https://admin.takos.example.com",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-worker"
        }
      }
    },
    {
      "serviceId": "takosumi",
      "runtime": "container",
      "hostingTargetId": "aws",
      "image": "ghcr.io/takos/takosumi:latest",
      "internalUrl": "http://takosumi.takos-system.svc.cluster.local:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi"
        }
      }
    },
    {
      "serviceId": "takosumi-cloud",
      "runtime": "container",
      "hostingTargetId": "aws",
      "image": "ghcr.io/takos/takosumi-cloud-accounts:latest",
      "internalUrl": "http://takosumi-cloud.takos-system.svc.cluster.local:8787",
      "publicUrl": "https://accounts.takos.example.com",
      "smoke": {
        "healthPath": "/healthz",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi-cloud"
        }
      }
    },
    {
      "serviceId": "takos-git",
      "runtime": "container",
      "hostingTargetId": "aws",
      "image": "ghcr.io/takos/takos-git:latest",
      "internalUrl": "http://takos-git.takos-system.svc.cluster.local:8790",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-git"
        }
      }
    },
    {
      "serviceId": "takos-agent",
      "runtime": "container",
      "hostingTargetId": "aws",
      "image": "ghcr.io/takos/takos-agent:latest",
      "internalUrl": "http://takos-agent.takos-system.svc.cluster.local:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-agent"
        }
      }
    }
  ],
  "metadata": {
    "official": true,
    "liveSmokeTask": "bun run distribution:smoke --manifest deploy/distributions/aws.json",
    "providerSmokeTask": "cd ../takosumi && TAKOSUMI_PLUGIN_LIVE_PROVIDER=aws TAKOSUMI_PLUGIN_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/aws.shape-v1.json bun run live-provisioning-smoke"
  }
}
