{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "environment": "production",
  "profile": "operator.takosumi.selfhosted",
  "artifacts": [
    {
      "kind": "opentofu",
      "ref": "deploy/opentofu/environments/selfhosted"
    },
    {
      "kind": "helm",
      "ref": "deploy/helm/takos/values-selfhosted.yaml"
    },
    {
      "kind": "compose",
      "ref": "../takos-private/compose.server.yml"
    }
  ],
  "providerProof": {
    "readOnlySmokeTask": "cd ../takosumi && TAKOSUMI_PROVIDER_LIVE_PROVIDER=selfhosted TAKOSUMI_PROVIDER_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/selfhosted.shape-v1.json bun run live-provisioning-smoke",
    "provisioningSmokeTask": "cd ../takosumi && TAKOSUMI_PROVIDER_LIVE_PROVIDER=selfhosted TAKOSUMI_PROVIDER_LIVE_PROOF_MODE=live TAKOSUMI_PROVIDER_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/selfhosted.shape-v1.json bun run live-provisioning-smoke",
    "cleanupTask": "cd ../takosumi && TAKOSUMI_PROVIDER_LIVE_PROVIDER=selfhosted TAKOSUMI_PROVIDER_LIVE_PROOF_MODE=live TAKOSUMI_PROVIDER_LIVE_CLEANUP_ONLY=1 TAKOSUMI_PROVIDER_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/selfhosted.shape-v1.json bun run live-provisioning-smoke",
    "fixturePath": "../takosumi/fixtures/live-provisioning/selfhosted.shape-v1.json",
    "liveEnvPrefix": "TAKOSUMI_PROVIDER_SELFHOSTED"
  },
  "requiredBindings": [
    {
      "kind": "container-engine",
      "name": "docker-or-podman"
    },
    {
      "kind": "reverse-proxy",
      "name": "caddy"
    }
  ],
  "target": {
    "id": "selfhosted",
    "host": "takos.example.internal",
    "baseUrl": "https://takos.example.internal",
    "composeProject": "takos",
    "reverseProxy": "caddy",
    "metadata": {
      "composeFile": "../takos-private/compose.server.yml",
      "operatorProfile": "operator.takosumi.selfhosted"
    }
  },
  "routing": {
    "publicBaseUrl": "https://takos.example.internal",
    "adminBaseUrl": "https://admin.takos.example.internal",
    "accountsBaseUrl": "https://accounts.takos.example.internal",
    "wildcardDomain": "*.app.takos.example.internal",
    "dnsProvider": "external"
  },
  "defaultApps": {
    "entries": [
      {
        "name": "takos-docs",
        "title": "Docs",
        "repositoryUrl": "https://github.com/tako0614/takos-docs.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-excel",
        "title": "Excel",
        "repositoryUrl": "https://github.com/tako0614/takos-excel.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-slide",
        "title": "Slide",
        "repositoryUrl": "https://github.com/tako0614/takos-slide.git",
        "ref": "v0.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "takos-computer",
        "title": "Computer",
        "repositoryUrl": "https://github.com/tako0614/takos-computer.git",
        "ref": "v2.1.2",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "yurucommu",
        "title": "Yurucommu",
        "repositoryUrl": "https://github.com/tako0614/yurucommu.git",
        "ref": "v1.2.6",
        "refType": "tag",
        "preinstall": true
      },
      {
        "name": "road-to-me",
        "title": "Road to Me",
        "repositoryUrl": "https://github.com/tako0614/road-to-me.git",
        "ref": "v0.1.0",
        "refType": "tag",
        "preinstall": false
      }
    ],
    "environmentOverrides": {
      "local": {
        "preinstall": []
      },
      "staging": {
        "preinstall": [
          "takos-docs",
          "takos-excel",
          "takos-slide",
          "takos-computer",
          "yurucommu"
        ]
      },
      "production": {
        "preinstall": [
          "takos-docs",
          "takos-excel",
          "takos-slide",
          "takos-computer",
          "yurucommu"
        ]
      }
    }
  },
  "services": [
    {
      "serviceId": "takos-worker",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takos-worker:latest",
      "internalUrl": "http://takos-worker:8080",
      "publicUrl": "https://admin.takos.example.internal",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-worker"
        }
      }
    },
    {
      "serviceId": "takosumi",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takosumi:latest",
      "internalUrl": "http://takosumi:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi"
        }
      }
    },
    {
      "serviceId": "takosumi-accounts",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takosumi-accounts:latest",
      "internalUrl": "http://takosumi-accounts:8787",
      "publicUrl": "https://accounts.takos.example.internal",
      "smoke": {
        "healthPath": "/healthz",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi-accounts"
        }
      }
    },
    {
      "serviceId": "takos-git",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takos-git:latest",
      "internalUrl": "http://takos-git:8790",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-git"
        }
      }
    },
    {
      "serviceId": "takos-agent",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takos-agent:latest",
      "internalUrl": "http://takos-agent:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-agent"
        }
      }
    }
  ],
  "metadata": {
    "official": true,
    "liveSmokeTask": "bun run distribution:smoke --manifest deploy/distributions/selfhosted.json",
    "providerSmokeTask": "cd ../takosumi && TAKOSUMI_PROVIDER_LIVE_PROVIDER=selfhosted TAKOSUMI_PROVIDER_LIVE_PROOF_FIXTURE_FILE=fixtures/live-provisioning/selfhosted.shape-v1.json bun run live-provisioning-smoke"
  },
  "operatorProfile": {
    "distribution": "takosumi",
    "profileId": "operator.takosumi.selfhosted",
    "implementationIds": [
      "operator.takosumi.selfhosted"
    ]
  }
}
