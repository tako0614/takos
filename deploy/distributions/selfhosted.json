{
  "apiVersion": "takosumi.com/hosting/v1",
  "kind": "TakosDistribution",
  "environment": "production",
  "profile": "@takosumi/plugins/profiles/selfhosted",
  "providerProfile": {
    "bundle": "@takosumi/plugins",
    "profileId": "operator.takosumi.selfhosted",
    "pluginIds": ["operator.takosumi.selfhosted"]
  },
  "artifacts": [
    {
      "kind": "compose",
      "ref": "../../takos-private/compose.server.yml"
    }
  ],
  "providerProof": {
    "readOnlySmokeTask": "cd ../../takosumi && deno task live-smoke:selfhosted",
    "provisioningSmokeTask": "cd ../../takosumi && deno task live-provisioning-smoke:selfhosted",
    "cleanupTask": "cd ../../takosumi && deno task live-provisioning-cleanup:selfhosted",
    "fixturePath": "../../takosumi/fixtures/live-provisioning/selfhosted.json",
    "liveEnvPrefix": "TAKOSUMI_PLUGIN_SELFHOSTED"
  },
  "requiredBindings": [
    {
      "kind": "container-engine",
      "name": "docker-or-podman"
    },
    {
      "kind": "reverse-proxy",
      "name": "caddy"
    }
  ],
  "target": {
    "id": "selfhosted",
    "host": "takos.example.internal",
    "baseUrl": "https://takos.example.internal",
    "composeProject": "takos",
    "reverseProxy": "caddy",
    "metadata": {
      "providerBundle": "@takosumi/plugins",
      "composeFile": "../../takos-private/compose.server.yml"
    }
  },
  "routing": {
    "publicBaseUrl": "https://takos.example.internal",
    "adminBaseUrl": "https://admin.takos.example.internal",
    "wildcardDomain": "*.app.takos.example.internal",
    "dnsProvider": "external"
  },
  "services": [
    {
      "serviceId": "takos-app",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takos-app:latest",
      "internalUrl": "http://takos-app:8080",
      "publicUrl": "https://admin.takos.example.internal",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-app"
        }
      }
    },
    {
      "serviceId": "takosumi",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takosumi:latest",
      "internalUrl": "http://takosumi:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takosumi"
        }
      }
    },
    {
      "serviceId": "takos-git",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takos-git:latest",
      "internalUrl": "http://takos-git:8790",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-git"
        }
      }
    },
    {
      "serviceId": "takos-agent",
      "runtime": "process",
      "hostingTargetId": "selfhosted",
      "image": "ghcr.io/takos/takos-agent:latest",
      "internalUrl": "http://takos-agent:8080",
      "smoke": {
        "healthPath": "/health",
        "expectedStatus": 200,
        "expectedJson": {
          "service": "takos-agent"
        }
      }
    }
  ],
  "metadata": {
    "official": true,
    "liveSmokeTask": "deno task distribution:smoke --manifest deploy/distributions/selfhosted.json",
    "providerSmokeTask": "cd ../../takosumi && deno task live-smoke:selfhosted"
  }
}
