{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://takos.jp/schemas/distribution/takos-distribution-profile-v1.json",
  "title": "Takos distribution profile v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "serviceId": {
      "description": "Logical service slot for the Takos distribution profile. The slot names are fixed for Takos release validation; replaceable operator distributions vary by artifact, endpoint, and implementation behind the slot, not by changing this service-id vocabulary.",
      "type": "string",
      "enum": ["takos-agent", "takos-git", "takos-worker"]
    },
    "jsonValue": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "environment",
    "profile",
    "operatorProfile",
    "artifacts",
    "providerProof",
    "requiredBindings",
    "target",
    "routing",
    "defaultApps",
    "services",
    "metadata"
  ],
  "properties": {
    "apiVersion": {
      "const": "takosumi.com/hosting/v1"
    },
    "kind": {
      "const": "TakosDistribution"
    },
    "environment": {
      "const": "production"
    },
    "profile": {
      "type": "string",
      "minLength": 1,
      "pattern": "^operator\\.takosumi\\.[a-z][a-z0-9-]*$"
    },
    "operatorProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distribution", "profileId", "implementationIds"],
      "properties": {
        "distribution": {
          "type": "string",
          "minLength": 1
        },
        "profileId": {
          "type": "string",
          "minLength": 1
        },
        "implementationIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "ref"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "providerProof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["liveEnvPrefix", "deployControlProofTask"],
      "properties": {
        "liveEnvPrefix": {
          "type": "string",
          "minLength": 1,
          "pattern": "^TAKOSUMI_PROVIDER_[A-Z0-9_]+$"
        },
        "deployControlProofTask": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "requiredBindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "name"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "target": {
      "type": "object",
      "required": ["id", "metadata"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publicBaseUrl",
        "adminBaseUrl",
        "wildcardDomain",
        "dnsProvider"
      ],
      "properties": {
        "publicBaseUrl": {
          "type": "string",
          "minLength": 1
        },
        "adminBaseUrl": {
          "type": "string",
          "minLength": 1
        },
        "wildcardDomain": {
          "type": "string",
          "minLength": 1
        },
        "dnsProvider": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "defaultApps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries", "environmentOverrides"],
      "properties": {
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "title",
              "repositoryUrl",
              "ref",
              "refType",
              "preinstall"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "appId": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$"
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "publisher": {
                "type": "string",
                "minLength": 1
              },
              "homepage": {
                "type": "string",
                "minLength": 1,
                "pattern": "^https://"
              },
              "icon": {
                "type": "string",
                "minLength": 1
              },
              "category": {
                "type": "string",
                "enum": ["app", "service", "library", "template", "social"]
              },
              "tags": {
                "type": "array",
                "maxItems": 10,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[a-z0-9][a-z0-9_-]*$"
                }
              },
              "repositoryUrl": {
                "type": "string",
                "minLength": 1,
                "pattern": "^https://"
              },
              "ref": {
                "type": "string",
                "minLength": 1
              },
              "refType": {
                "type": "string",
                "enum": ["branch", "tag", "commit"]
              },
              "preinstall": {
                "type": "boolean"
              },
              "sourcePath": {
                "type": "string",
                "minLength": 1
              },
              "modulePath": {
                "type": "string",
                "minLength": 1
              },
              "variables": {
                "type": "object",
                "propertyNames": {
                  "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                },
                "additionalProperties": {
                  "$ref": "#/$defs/jsonValue"
                }
              },
              "runtimeModes": {
                "type": "array",
                "minItems": 1,
                "maxItems": 3,
                "items": {
                  "type": "string",
                  "enum": ["shared-cell", "dedicated", "self-hosted"]
                }
              },
              "bindings": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "type", "required"],
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "type": {
                      "type": "string",
                      "minLength": 1
                    },
                    "required": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "backendName": {
                "type": "string",
                "enum": ["cloudflare", "local", "aws", "gcp", "k8s"]
              },
              "envName": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "environmentOverrides": {
          "type": "object",
          "additionalProperties": false,
          "required": ["local", "staging", "production"],
          "properties": {
            "local": {
              "type": "object",
              "additionalProperties": false,
              "required": ["preinstall"],
              "properties": {
                "preinstall": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "staging": {
              "type": "object",
              "additionalProperties": false,
              "required": ["preinstall"],
              "properties": {
                "preinstall": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "production": {
              "type": "object",
              "additionalProperties": false,
              "required": ["preinstall"],
              "properties": {
                "preinstall": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["serviceId", "runtime", "hostingTargetId"],
        "anyOf": [
          {
            "required": ["image"]
          },
          {
            "required": ["artifactRef"]
          }
        ],
        "properties": {
          "serviceId": {
            "$ref": "#/$defs/serviceId"
          },
          "runtime": {
            "type": "string",
            "enum": ["container", "worker", "process"]
          },
          "hostingTargetId": {
            "type": "string",
            "minLength": 1
          },
          "image": {
            "type": "string",
            "minLength": 1
          },
          "artifactRef": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "internalUrl": {
            "type": "string",
            "minLength": 1
          },
          "publicUrl": {
            "type": "string",
            "minLength": 1
          },
          "smoke": {
            "type": "object",
            "additionalProperties": false,
            "required": ["healthPath", "expectedStatus", "expectedJson"],
            "properties": {
              "healthPath": {
                "enum": ["/health", "/healthz"]
              },
              "expectedStatus": {
                "const": 200
              },
              "expectedJson": {
                "type": "object",
                "additionalProperties": false,
                "required": ["service"],
                "properties": {
                  "service": {
                    "$ref": "#/$defs/serviceId"
                  }
                }
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["official", "releaseGateTask"],
      "properties": {
        "official": {
          "type": "boolean"
        },
        "releaseGateTask": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
