# OAuth mock — stands in for accounts.google.com + github.com so the
# cloud sign-in flow can complete in local-substrate without external
# network. See deploy/local-substrate/oauth-mock/main.ts for routes.
oauth-mock.test {
	encode gzip
	reverse_proxy oauth-mock:8789
}

# cloud.takosumi.com mirror — dashboard SPA at "/", API paths to the worker.
#
# Wrap in `route { ... handle ... }` so Caddy evaluates the API handler before
# the SPA fallback. Without explicit `route`+`handle` blocks, Caddy's directive
# sorter puts the catch-all `handle` first and the worker is never reached.
cloud.takosumi.test {
	route {
		# API routes — accounts-service constants live under /v1/*, plus
		# legacy /oauth/* (OIDC server) and /.well-known/* (discovery).
		@api path /v1/* /oauth/* /.well-known/* /healthz
		handle @api {
			reverse_proxy takosumi-cloud-worker:8787
		}

		# SPA static + client-side routing fallback for everything else
		handle {
			encode gzip
			root * /srv/takosumi-cloud-dashboard
			try_files {path} {path}/ /index.html
			file_server
		}
	}
}

accounts.takos.test {
	reverse_proxy accounts:8787
}

kernel.takos.test {
	reverse_proxy kernel:8788
}

app.takos.test {
	reverse_proxy takos-app:8787
}

git.takos.test {
	reverse_proxy takos-git:8790
}

