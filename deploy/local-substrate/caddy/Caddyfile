{
	acme_ca https://pebble:14000/dir
	acme_ca_root /runtime/pebble.minica.pem
	admin 0.0.0.0:2019
}

hello.takos.test {
	respond "hello from local-substrate (Phase 0)" 200
}

# takosumi.com mirror — marketing landing at "/", docs at "/docs/*".
takosumi.test {
	encode gzip

	# Docs (VitePress dist; built with base="/docs/").
	handle_path /docs/* {
		root * /srv/takosumi-docs
		try_files {path} {path}/ {path}.html /index.html
		file_server
	}

	# Marketing landing (vanilla HTML/CSS in takosumi/website/).
	handle {
		root * /srv/takosumi-marketing
		try_files {path} {path}/index.html /index.html
		file_server
	}
}

# cloud.takosumi.com mirror — dashboard SPA at "/", API paths to the worker.
cloud.takosumi.test {
	encode gzip

	# API routes (defined as a named matcher to keep this DRY)
	@api {
		path /.well-known/* /oauth/* /passkey/* /installations/*
		path /dashboard/* /stripe/* /upstream/* /v1/auth/*
		path /account/tokens /healthz
	}
	reverse_proxy @api takosumi-cloud-worker:8787

	# SPA static + client-side routing fallback for everything else
	handle {
		root * /srv/takosumi-cloud-dashboard
		try_files {path} {path}/ /index.html
		file_server
	}
}

accounts.takos.test {
	reverse_proxy accounts:8787
}

kernel.takos.test {
	reverse_proxy kernel:8788
}

app.takos.test {
	reverse_proxy takos-app:8787
}

git.takos.test {
	reverse_proxy takos-git:8790
}

# Phase 3 で route-registrar が *.app.takos.test に動的 route を追加する。
# Phase 1 では catch-all 404 にしておく。
