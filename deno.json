{
  "workspace": [
    "./apps/cli",
    "./apps/control",
    "./apps/runtime",
    "./docs",
    "./packages/common",
    "./packages/actions-engine",
    "./packages/runtime-service",
    "./packages/browser-service",
    "./packages/control",
    "./packages/control/local-platform",
    "./scripts"
  ],
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "dom", "dom.iterable"],
    "types": ["node"]
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any",
        "no-import-prefix",
        "no-process-global",
        "no-unversioned-import",
        "no-unsafe-finally",
        "require-await"
      ]
    }
  },
  "tasks": {
    "build:all": "echo 'No tsc build needed — Deno runs .ts directly'",
    "test:all": "deno test --allow-all --ignore=packages/actions-engine/dist",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "docs:dev": "deno task --cwd docs dev",
    "docs:build": "deno task --cwd docs build",
    "docs:deploy": "deno task --cwd docs deploy",
    "local:up": "docker compose --env-file ${TAKOS_LOCAL_ENV_FILE:-.env.local} -f compose.local.yml up --build",
    "local:down": "docker compose --env-file ${TAKOS_LOCAL_ENV_FILE:-.env.local} -f compose.local.yml down --remove-orphans",
    "check:boundaries": "deno run --allow-read scripts/check-boundaries.mjs",
    "dev:takos": "deno task --cwd apps/control dev",
    "dev:runtime": "deno task --cwd apps/runtime dev",
    "dev:cli": "deno task --cwd apps/cli dev",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf {} + && find . -name 'dist' -type d -prune -exec rm -rf {} +"
  }
}
