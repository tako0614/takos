{
  "takosRelease": {
    "name": "takos",
    "version": "0.9.0"
  },
  "tasks": {
    "doctor": "node scripts/doctor.mjs",
    "check": "node scripts/doctor.mjs --check",
    "local:config": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml config'",
    "local:up": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml up --build'",
    "local:down": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml down'",
    "local:logs": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml logs -f'",
    "local:smoke": "deno run --allow-net --allow-env --allow-read scripts/local-smoke.mjs",
    "local:e2e": "deno run --allow-run=docker,bash,git --allow-net=127.0.0.1 --allow-env --allow-read --allow-write scripts/local-e2e.mjs",
    "docs:dev": "deno task --cwd docs dev",
    "lint:docs": "deno task docs:build",
    "lint:agent-docs": "deno task validate:agent-docs",
    "docs:build": "deno task --cwd docs build",
    "docs:deploy": "deno task --cwd docs deploy",
    "validate:api-docs": "deno run --config deno.json --allow-read scripts/validate-api-docs.ts",
    "validate:current-docs": "deno run --config deno.json --allow-read scripts/validate-current-docs.ts",
    "helm:generate-overlays": "deno run --config deno.json --allow-read --allow-write=deploy/helm/takos scripts/generate-helm-overlays.ts",
    "helm:check-overlays": "deno run --config deno.json --allow-read scripts/generate-helm-overlays.ts --check",
    "helm:template-smoke": "deno run --config deno.json --allow-run=helm --allow-read --allow-env=TAKOS_HELM_REQUIRE_INSTALL_DRY_RUN,TAKOS_HELM_INSTALL_TEST_CRDS scripts/helm-template-smoke.ts",
    "helm:install-smoke": "deno run --config deno.json --allow-run=helm --allow-read --allow-env=TAKOS_HELM_INSTALL_TEST_CRDS scripts/helm-install-smoke.ts",
    "terraform:helm-values": "deno run --config deno.json --allow-read --allow-write=deploy/helm/takos --allow-run=terraform scripts/terraform-output-to-helm-values.ts",
    "terraform:helm-values:check": "deno run --config deno.json --allow-read scripts/terraform-output-to-helm-values.ts --check-fixtures",
    "terraform:plan-gate": "deno run --config deno.json --allow-read --allow-write=.terraform-plan --allow-run --allow-env=TAKOS_TERRAFORM_BIN scripts/terraform-plan-gate.ts",
    "validate:terraform-secrets": "deno run --config deno.json --allow-read --allow-run=git scripts/validate-terraform-secret-policy.ts",
    "validate:helm": "deno run --config deno.json --allow-read scripts/validate-helm-chart.ts",
    "validate:agent-docs": "deno run --config deno.json --allow-read --allow-env=TAKOS_ECOSYSTEM_ROOT scripts/validate-agent-docs.ts",
    "validate:architecture": "deno run --config deno.json --allow-read scripts/validate-architecture-alignment.ts",
    "validate:distributions": "deno run --config deno.json --allow-read scripts/validate-distribution-profiles.ts",
    "validate:observability": "deno run --config deno.json --allow-read scripts/validate-observability-artifacts.ts",
    "validate:patch-management": "deno run --config deno.json --allow-read scripts/validate-patch-management.ts",
    "validate:migration-safety": "deno task --cwd app validate:migration-safety",
    "validate:retired-route-removal": "deno run --config deno.json --allow-read --allow-run=deno,git scripts/validate-retired-route-evidence.ts",
    "validate:legal-docs": "deno run --config deno.json --allow-read scripts/validate-legal-docs.ts",
    "validate:release-promotion": "deno run --config deno.json --allow-read scripts/validate-release-promotion.ts",
    "validate:service-set": "deno run --config deno.json --allow-read scripts/validate-service-set.ts",
    "validate:process-roles": "deno task validate:service-set",
    "distribution:smoke": "deno run --config deno.json --allow-read --allow-env --allow-net scripts/distribution-smoke.ts",
    "release-gate": "deno run --config deno.json --allow-read --allow-run scripts/release-gate.ts",
    "release-manifest:check-clean": "deno run --config deno.json --allow-read --allow-run=git scripts/build-release-manifest.ts --require-clean-git",
    "release-manifest:check-artifacts": "deno run --config deno.json --allow-read --allow-run=git scripts/build-release-manifest.ts --require-clean-git --require-image-digests",
    "submodules:update": "git submodule update --init --recursive"
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true,
    "exclude": [
      "app/",
      "agent/",
      "git/",
      "node_modules/",
      "CLA.md",
      "CONTRIBUTING.md",
      "SECURITY.md",
      ".github/",
      "docs/",
      ".terraform-plan/",
      "deploy/distribution-contract/",
      "deploy/helm/takos/templates",
      "deploy/helm/takos/Chart.yaml",
      "deploy/helm/takos/values.yaml",
      "deploy/helm/takos/values-aws.yaml",
      "deploy/helm/takos/values-gcp.yaml",
      "deploy/terraform/testdata/helm-values/"
    ]
  },
  "lint": {
    "exclude": [
      "app/",
      "agent/",
      "git/",
      "node_modules/",
      "docs/.vitepress/cache/",
      "docs/.vitepress/dist/",
      ".terraform-plan/"
    ],
    "rules": {
      "tags": ["recommended"],
      "include": ["no-eval"]
    }
  }
}
