{
  "tasks": {
    "doctor": "node scripts/doctor.mjs",
    "check": "node scripts/doctor.mjs --check",
    "local:config": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml config'",
    "local:up": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml up --build'",
    "local:down": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml down'",
    "local:logs": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml logs -f'",
    "local:smoke": "deno run --allow-net --allow-env --allow-read scripts/local-smoke.mjs",
    "local:e2e": "deno run --allow-run=docker,bash,git --allow-net=127.0.0.1 --allow-env --allow-read --allow-write scripts/local-e2e.mjs",
    "docs:dev": "deno task --cwd docs dev",
    "docs:build": "deno task --cwd docs build",
    "helm:generate-overlays": "deno run --config deno.json --allow-read --allow-write=deploy/helm/takos scripts/generate-helm-overlays.ts",
    "helm:check-overlays": "deno run --config deno.json --allow-read scripts/generate-helm-overlays.ts --check",
    "helm:template-smoke": "deno run --config deno.json --allow-run=helm --allow-read --allow-env=TAKOS_HELM_REQUIRE_INSTALL_DRY_RUN,TAKOS_HELM_INSTALL_TEST_CRDS scripts/helm-template-smoke.ts",
    "validate:helm": "deno run --config deno.json --allow-read scripts/validate-helm-chart.ts",
    "validate:agent-docs": "deno run --config deno.json --allow-read --allow-env=TAKOS_ECOSYSTEM_ROOT scripts/validate-agent-docs.ts",
    "validate:architecture": "deno run --config deno.json --allow-read scripts/validate-architecture-alignment.ts",
    "validate:distributions": "deno run --config deno.json --allow-read scripts/validate-distribution-profiles.ts",
    "validate:service-set": "deno run --config deno.json --allow-read scripts/validate-service-set.ts",
    "validate:process-roles": "deno task validate:service-set",
    "distribution:smoke": "deno run --config deno.json --allow-read --allow-env --allow-net scripts/distribution-smoke.ts",
    "release-gate": "deno run --config deno.json --allow-read --allow-run scripts/release-gate.ts",
    "submodules:update": "git submodule update --init --recursive"
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true,
    "exclude": [
      "deploy/helm/takos/templates",
      "docs/**/*.md"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": ["no-eval"]
    }
  }
}
