{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable",
      "DOM.AsyncIterable"
    ],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "types": [
      "bun",
      "node"
    ],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@std/assert": [
        "./shims/std/assert.ts"
      ],
      "@std/fmt/colors": [
        "./shims/std/colors.ts"
      ],
      "@std/testing/mock": [
        "./shims/std/mock.ts"
      ],
      "takosumi-contract/internal/rpc": [
        "../../../takosumi/src/contract/internal-rpc.ts"
      ],
      "@takos/takosumi-contract": [
        "../../../takosumi/src/contract/index.ts"
      ],
      "takos-git-contract": [
        "../../src/contracts/git/index.ts"
      ],
      "takos-git-contract/*": [
        "../../src/contracts/git/*"
      ]
    }
  },
  "include": [
    "scripts",
    "src",
    "shims"
  ]
}
