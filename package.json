{
  "name": "@takos/takos",
  "version": "0.9.0",
  "takosRelease": {
    "name": "takos",
    "version": "0.9.0"
  },
  "license": "AGPL-3.0-only",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --preload ./shims/deno-compat.ts src/worker/local-platform/unified-entrypoint.ts",
    "dev:api": "bun --preload ./shims/deno-compat.ts src/worker/local-platform/unified-entrypoint.ts",
    "dev:worker": "bun --preload ./shims/deno-compat.ts src/worker/local-platform/unified-entrypoint.ts",
    "dev:web": "bunx vite --host 0.0.0.0 --config web/vite.config.ts",
    "web:dev": "bun run dev:web",
    "web:build": "bunx vite build --config web/vite.config.ts",
    "web:check": "bun run web:build",
    "build": "bun run web:build",
    "doctor": "bun scripts/doctor.mjs",
    "local:config": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml config'",
    "local:up": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml up --build'",
    "local:down": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml down'",
    "local:logs": "bash -lc 'docker compose --env-file \"${TAKOS_LOCAL_ENV_FILE:-.env.local.example}\" -p \"${TAKOS_LOCAL_COMPOSE_PROJECT:-takos-local}\" -f compose.local.yml logs -f'",
    "local:smoke": "bun --preload ./shims/deno-compat.ts scripts/local-smoke.mjs",
    "local:e2e": "bun --preload ./shims/deno-compat.ts scripts/local-e2e.mjs",
    "docs:dev": "bunx vitepress dev docs",
    "docs:build": "bunx vitepress build docs",
    "docs:deploy": "bunx wrangler pages deploy docs/.vitepress/dist --project-name takos-docs",
    "lint:docs": "bun run docs:build",
    "lint:agent-docs": "bun run validate:agent-docs",
    "check": "tsc -p tsconfig.check.json --noEmit",
    "test": "bun test ./src/worker/platform-utils ./src/contracts/public ./src/worker/actions-engine ./src/contracts/deploy-intent ./src/contracts",
    "test:common": "bun test ./src/worker/platform-utils",
    "test:actions-engine": "bun test ./src/worker/actions-engine",
    "test:deploy-intent": "bun test ./src/contracts/deploy-intent",
    "validate:api-docs": "bun --preload ./shims/deno-compat.ts scripts/validate-api-docs.ts",
    "validate:current-docs": "bun --preload ./shims/deno-compat.ts scripts/validate-current-docs.ts",
    "helm:generate-overlays": "bun --preload ./shims/deno-compat.ts scripts/generate-helm-overlays.ts",
    "helm:check-overlays": "bun --preload ./shims/deno-compat.ts scripts/generate-helm-overlays.ts --check",
    "helm:template-smoke": "bun --preload ./shims/deno-compat.ts scripts/helm-template-smoke.ts",
    "helm:install-smoke": "bun --preload ./shims/deno-compat.ts scripts/helm-install-smoke.ts",
    "terraform:helm-values": "bun --preload ./shims/deno-compat.ts scripts/terraform-output-to-helm-values.ts",
    "terraform:helm-values:check": "bun --preload ./shims/deno-compat.ts scripts/terraform-output-to-helm-values.ts --check-fixtures",
    "terraform:plan-gate": "bun --preload ./shims/deno-compat.ts scripts/terraform-plan-gate.ts",
    "validate:terraform-secrets": "bun --preload ./shims/deno-compat.ts scripts/validate-terraform-secret-policy.ts",
    "validate:helm": "bun --preload ./shims/deno-compat.ts scripts/validate-helm-chart.ts",
    "validate:agent-docs": "bun --preload ./shims/deno-compat.ts scripts/validate-agent-docs.ts",
    "validate:architecture": "bun --preload ./shims/deno-compat.ts scripts/validate-architecture-alignment.ts",
    "validate:distributions": "bun --preload ./shims/deno-compat.ts scripts/validate-distribution-profiles.ts",
    "validate:observability": "bun --preload ./shims/deno-compat.ts scripts/validate-observability-artifacts.ts",
    "validate:patch-management": "bun --preload ./shims/deno-compat.ts scripts/validate-patch-management.ts",
    "validate:migration-safety": "bun --preload ./shims/deno-compat.ts scripts/validate-migration-safety.ts",
    "validate:retired-route-removal": "bun --preload ./shims/deno-compat.ts scripts/validate-retired-route-evidence.ts",
    "validate:legal-docs": "bun --preload ./shims/deno-compat.ts scripts/validate-legal-docs.ts",
    "validate:release-promotion": "bun --preload ./shims/deno-compat.ts scripts/validate-release-promotion.ts",
    "validate:service-set": "bun --preload ./shims/deno-compat.ts scripts/validate-service-set.ts",
    "validate:process-roles": "bun run validate:service-set",
    "distribution:smoke": "bun --preload ./shims/deno-compat.ts scripts/distribution-smoke.ts",
    "generate:agent-prompts": "bun --preload ./shims/deno-compat.ts scripts/generate-agent-prompts.ts",
    "release-gate": "bun --preload ./shims/deno-compat.ts scripts/release-gate.ts",
    "release-manifest:check-clean": "bun --preload ./shims/deno-compat.ts scripts/build-release-manifest.ts --require-clean-git",
    "release-manifest:check-artifacts": "bun --preload ./shims/deno-compat.ts scripts/build-release-manifest.ts --require-clean-git --require-image-digests",
    "deploy:service": "bun scripts/control/deploy.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@cloudflare/containers": "^0.3.5",
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/pubsub": "^4.9.0",
    "@google-cloud/storage": "^7.14.0",
    "@langchain/core": "^1.1.8",
    "@langchain/langgraph": "^1.0.7",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/openai": "^1.2.0",
    "@libsql/client": "^0.17.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solid-primitives/storage": "^4.3.4",
    "@solidjs/router": "^0.16.1",
    "drizzle-orm": "^0.45.1",
    "fflate": "^0.8.2",
    "google-auth-library": "^10.6.2",
    "hono": "^4.12.4",
    "jose": "^5.9.0",
    "jszip": "^3.10.1",
    "miniflare": "^4.20260124.0",
    "monaco-editor": "^0.55.1",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "solid-js": "^1.9.13",
    "yaml": "^2.8.2",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12",
    "vitepress": "^1.6.4",
    "wrangler": "^4.95.0"
  }
}
