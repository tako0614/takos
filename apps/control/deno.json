    "solid-js/web": "npm:solid-js@^1.9.12/web",
    "wrangler": "npm:wrangler@^4.61.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9"
  },
  "tasks": {
    "dev": "deno run -A npm:wrangler dev",
    "dev:local:web": "deno run --allow-all ../../packages/control/local-platform/src/web.ts",
    "dev:local:dispatch": "deno run --allow-all ../../packages/control/local-platform/src/dispatch.ts",
    "dev:local:runtime-host": "deno run --allow-all ../../packages/control/local-platform/src/runtime-host.ts",
    "dev:local:executor-host": "deno run --allow-all ../../packages/control/local-platform/src/executor-host.ts",
    "dev:local:browser-host": "deno run --allow-all ../../packages/control/local-platform/src/browser-host.ts",
    "dev:local:oci-orchestrator": "deno run --allow-all ../../packages/control/local-platform/src/oci-orchestrator.ts",
    "dev:local:worker": "deno run --allow-all ../../packages/control/local-platform/src/worker.ts",
    "dev:local:run-smoke": "deno run --allow-all ../../packages/control/local-platform/src/run-smoke.ts",
    "dev:local:run-smoke-proxyless": "deno run --allow-all ../../packages/control/local-platform/src/run-smoke-proxyless.ts",
    "dev:frontend": "deno run --node-modules-dir=auto -A npm:vite --config web/vite.config.ts",
    "build": "deno run --node-modules-dir=auto -A npm:vite build --config web/vite.config.ts",
    "deploy:service": "deno run --allow-all scripts/deploy.mjs",
    "db:generate": "deno run -A npm:drizzle-kit generate",
    "db:push": "deno run -A npm:drizzle-kit push",
    "db:migrate": "deno run -A npm:wrangler d1 migrations apply DB --local",
    "test": "deno test --allow-all src/",
    "test:coverage": "deno test --allow-all --coverage src/"
  }
}
