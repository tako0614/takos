    "@/queues/workflow-events": "../../packages/control/src/queues/workflow-events.ts",
    "@/queues/workflow-steps": "../../packages/control/src/queues/workflow-steps.ts",
    "@/queues/workflow-runtime-client": "../../packages/control/src/queues/workflow-runtime-client.ts",
    "@/queues/workflow-expressions": "../../packages/control/src/queues/workflow-expressions.ts",
    "@/queues/workflow-dlq": "../../packages/control/src/queues/workflow-dlq.ts",
