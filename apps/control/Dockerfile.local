FROM denoland/deno:latest AS builder
WORKDIR /workspace
ENV DENO_DIR=/deno-dir

COPY deno.json deno.lock* ./
COPY packages ./packages
COPY apps/control ./apps/control
COPY apps/runtime ./apps/runtime
COPY apps/cli ./apps/cli
COPY docs ./docs
COPY scripts ./scripts

RUN deno cache \
  packages/control/local-platform/src/web.ts \
  packages/control/local-platform/src/dispatch.ts \
  packages/control/local-platform/src/runtime-host.ts \
  packages/control/local-platform/src/executor-host.ts \
  packages/control/local-platform/src/browser-host.ts \
  packages/control/local-platform/src/worker.ts \
  packages/control/local-platform/src/oci-orchestrator.ts

FROM denoland/deno:latest
WORKDIR /workspace
ENV DENO_DIR=/deno-dir

RUN apt-get update && apt-get install -y --no-install-recommends openssl ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /workspace /workspace
COPY --from=builder /deno-dir /deno-dir

RUN useradd -r -m takos && chown -R takos:takos /workspace
USER takos

ENV NODE_ENV=production

WORKDIR /workspace/apps/control
