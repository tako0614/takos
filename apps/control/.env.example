# =============================================================================
# Takos Cloudflare Deploy Template
# =============================================================================
# This file lists the main vars and secrets used by the tracked wrangler
# templates under apps/control/.
#
# Use it as a checklist for:
# - wrangler.toml
# - wrangler.dispatch.toml
# - wrangler.worker.toml
# - wrangler.runtime-host.toml
# - wrangler.executor.toml
# - wrangler.browser-host.toml
#
# Non-secret values belong in wrangler [vars]. Secret values belong in
# `wrangler secret put`.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared domains
# -----------------------------------------------------------------------------
ADMIN_DOMAIN=admin.example.com
TENANT_BASE_DOMAIN=app.example.com

# -----------------------------------------------------------------------------
# Google OAuth (wrangler.toml)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Platform keys (wrangler.toml)
# -----------------------------------------------------------------------------
PLATFORM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
PLATFORM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Optional defense-in-depth key for runtime-host request verification.
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# -----------------------------------------------------------------------------
# Cloudflare account / dispatch (wrangler.toml, wrangler.worker.toml)
# -----------------------------------------------------------------------------
# Local/node platform reads CLOUDFLARE_* preferred, with CF_* as fallback.
# Cloudflare Workers (wrangler.toml [vars]) only see CF_* — that is the
# canonical name in production. Set both for portability.
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
WFP_DISPATCH_NAMESPACE=your-dispatch-namespace
CF_ZONE_ID=your-cloudflare-zone-id

# -----------------------------------------------------------------------------
# Runtime / executor host vars
# -----------------------------------------------------------------------------
PROXY_BASE_URL=https://your-runtime-host.workers.dev
CONTROL_RPC_BASE_URL=https://your-executor-host.workers.dev

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# -----------------------------------------------------------------------------
# AI provider keys (worker / executor-host)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Optional search provider
SERPER_API_KEY=your-serper-api-key

# -----------------------------------------------------------------------------
# Billing / auth extras
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLUS_PRICE_ID=price_plus_...
STRIPE_PRO_TOPUP_PACKS_JSON=[{"id":"starter","label":"Starter","price_id":"price_...","credits_cents":2500}]
TURNSTILE_SECRET_KEY=0x...

# Optional executor control-plane forwarding secret.
# EXECUTOR_PROXY_SECRET=replace-me

# =============================================================================
# Bindings are configured in wrangler*.toml, not in this file.
# =============================================================================
# Main bindings used by the tracked templates:
# - D1: DB
# - KV: HOSTNAME_ROUTING
# - Durable Objects: SESSION_DO, RUN_NOTIFIER, NOTIFICATION_NOTIFIER,
#   RATE_LIMITER_DO, ROUTING_DO, GIT_PUSH_LOCK,
#   RUNTIME_CONTAINER, EXECUTOR_CONTAINER, BROWSER_CONTAINER
# - R2: WORKER_BUNDLES, TENANT_BUILDS, TENANT_SOURCE, GIT_OBJECTS,
#   TAKOS_OFFLOAD, BROWSER_CHECKPOINTS
# - Queues: RUN_QUEUE, INDEX_QUEUE, WORKFLOW_QUEUE, DEPLOY_QUEUE
# - AI: VECTORIZE, AI
# - Services: TAKOS_EGRESS, RUNTIME_HOST, BROWSER_HOST, TAKOS_CONTROL
