# =============================================================================
# Takos OSS Deployment Template - Environment Variables
# =============================================================================
# This file documents all environment variables used by takos-control.
# Copy this file to .dev.vars for local development.
#
# Variables can be set in three ways:
# 1. wrangler.toml [vars] section - Non-sensitive configuration
# 2. wrangler secret put <NAME> - Sensitive secrets (recommended)
# 3. .dev.vars file - Local development only (git-ignored)
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration (Required)
# Set in wrangler.toml [vars]
# -----------------------------------------------------------------------------
ADMIN_DOMAIN=admin.example.com
TENANT_BASE_DOMAIN=app.example.com

# -----------------------------------------------------------------------------
# Google OAuth (Required)
# Set via:
#   - wrangler.toml [vars] / [env.staging.vars]: GOOGLE_CLIENT_ID
#   - wrangler secret put GOOGLE_CLIENT_SECRET
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Platform JWT Keys (Required)
# RSA key pair for signing/verifying platform tokens
# Generate with: openssl genrsa -out private.pem 2048
#                openssl rsa -in private.pem -pubout -out public.pem
# Set via: wrangler secret put PLATFORM_PRIVATE_KEY
#          wrangler secret put PLATFORM_PUBLIC_KEY
# -----------------------------------------------------------------------------
PLATFORM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
PLATFORM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# -----------------------------------------------------------------------------
# Cloudflare API (Required for Workers for Platforms)
# Set via: wrangler secret put CF_API_TOKEN
# wrangler.toml [vars]: CF_ACCOUNT_ID, CF_ZONE_ID
# -----------------------------------------------------------------------------
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
WFP_DISPATCH_NAMESPACE=your-dispatch-namespace

# Cloudflare Zone ID (Optional - for custom domains / SSL for SaaS)
CF_ZONE_ID=your-zone-id

# -----------------------------------------------------------------------------
# Billing Catalog / Price IDs (Optional)
# Set in wrangler.toml [vars] / [env.staging.vars]
# -----------------------------------------------------------------------------
STRIPE_PLUS_PRICE_ID=price_plus_...
STRIPE_PRO_TOPUP_PACKS_JSON=[{"id":"starter","label":"Starter","price_id":"price_...","credits_cents":2500}]

# Note: SERVICE_JWT keys are no longer needed. Service-to-service auth uses
# service bindings (X-Takos-Internal: 1) and DO-local random tokens.

# -----------------------------------------------------------------------------
# AI Provider API Keys (Optional)
# Set via: wrangler secret put <KEY_NAME>
# At least one is required for agent functionality
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# -----------------------------------------------------------------------------
# Agent Configuration (Optional)
# Can be set in wrangler.toml [vars]
# -----------------------------------------------------------------------------
MAX_AGENT_ITERATIONS=50
AGENT_TEMPERATURE=0.7
AGENT_RATE_LIMIT=100

# -----------------------------------------------------------------------------
# Web Search API (Optional - Serper.dev)
# -----------------------------------------------------------------------------
SERPER_API_KEY=your-serper-api-key

# -----------------------------------------------------------------------------
# Cloudflare Turnstile Bot Protection (Optional)
# If not set, Turnstile verification is skipped (development mode).
# Set via: wrangler secret put TURNSTILE_SECRET_KEY
# -----------------------------------------------------------------------------
# TURNSTILE_SECRET_KEY=0x...

# -----------------------------------------------------------------------------
# Encryption (Optional but Recommended)
# For encrypting sensitive data (env vars, secrets)
# Generate with: openssl rand -base64 32
# Set via: wrangler secret put ENCRYPTION_KEY
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# =============================================================================
# Cloudflare Bindings (Configured in wrangler.toml, not here)
# =============================================================================
# The following are configured as bindings in wrangler.toml:
#
# D1 Database:
#   binding = "DB"
#
# KV Namespaces:
#   binding = "HOSTNAME_ROUTING"
#
# Durable Objects:
#   binding = "SESSION_DO"       - Session management
#   binding = "RUN_NOTIFIER"     - Real-time run events (SSE)
#   binding = "RATE_LIMITER_DO"  - Distributed rate limiting (optional)
#
# R2 Buckets:
#   binding = "WORKER_BUNDLES"   - Worker bundle storage
#   binding = "TENANT_BUILDS"    - Tenant custom workers
#   binding = "TENANT_SOURCE"    - Tenant source code
#   binding = "GIT_OBJECTS"     - Version control objects
#
# Queues:
#   binding = "RUN_QUEUE"        - Agent run execution
#   binding = "RUN_DLQ"          - Failed runs (dead letter)
#   binding = "INDEX_QUEUE"      - Index jobs (embeddings)
#   binding = "WORKFLOW_QUEUE"   - Workflow job execution (optional)
#
# AI/ML:
#   binding = "VECTORIZE"        - Semantic search vectors
#   binding = "AI"               - Cloudflare AI (embeddings)
#
# Other:
#   binding = "DISPATCHER"       - Workers for Platforms
#   binding = "BROWSER"          - Browser rendering (Puppeteer)
#   binding = "ASSETS"           - Static assets
#   binding = "RUNTIME_HOST"     - Runtime host service binding (CF Containers)
# =============================================================================
