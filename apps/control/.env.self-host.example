# =============================================================================
# Takos Manual Local-Platform / Self-Host Template
# =============================================================================
# Legacy filename retained for operator convenience.
# The current entrypoints are:
#   PORT=8787 corepack pnpm -C apps/control dev:local:web
#   PORT=8788 corepack pnpm -C apps/control dev:local:dispatch
#   PORT=8789 corepack pnpm -C apps/control dev:local:runtime-host
#   PORT=8790 corepack pnpm -C apps/control dev:local:executor-host
#   PORT=8791 corepack pnpm -C apps/control dev:local:browser-host
#   corepack pnpm -C apps/control dev:local:worker
#   corepack pnpm -C apps/control dev:local:oci-orchestrator
#
# Prefer `.env.local.example` when you use Docker Compose. This file is for
# manual/self-host wiring where you run the local-platform entrypoints directly.
# =============================================================================

TAKOS_ADMIN_DOMAIN=admin.localhost
TAKOS_TENANT_BASE_DOMAIN=app.localhost

TAKOS_CONTROL_WEB_PORT=8787
TAKOS_CONTROL_DISPATCH_PORT=8788
TAKOS_RUNTIME_HOST_PORT=8789
TAKOS_EXECUTOR_HOST_PORT=8790
TAKOS_BROWSER_HOST_PORT=8791

TAKOS_CONTROL_WORKER_POLL_INTERVAL_MS=250
TAKOS_CONTROL_WORKER_SCHEDULED_INTERVAL_MS=60000
TAKOS_CONTROL_WORKER_HEARTBEAT_FILE=/var/lib/takos/control/worker-heartbeat.json
TAKOS_CONTROL_WORKER_HEARTBEAT_TTL_MS=120000

TAKOS_LOCAL_DATA_DIR=/var/lib/takos/control
TAKOS_LOCAL_RUNTIME_URL=http://127.0.0.1:8789/
TAKOS_LOCAL_EXECUTOR_URL=http://127.0.0.1:8790/
TAKOS_LOCAL_BROWSER_URL=http://127.0.0.1:8791/

TAKOS_OCI_ORCHESTRATOR_PORT=9002
OCI_ORCHESTRATOR_URL=http://127.0.0.1:9002/
OCI_ORCHESTRATOR_DATA_DIR=/var/lib/takos/control/oci-orchestrator
# OCI_ORCHESTRATOR_TOKEN=replace-me

CONTROL_RPC_BASE_URL=http://127.0.0.1:8790/
DATABASE_URL=postgresql://takos:takos@127.0.0.1:5432/takos
REDIS_URL=redis://127.0.0.1:6379
TAKOS_ALLOW_NO_LLM=1

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=takos
S3_SECRET_ACCESS_KEY=takos-dev-secret
S3_BUCKET=takos-tenant-source

PLATFORM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
PLATFORM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# Optional Cloudflare target configuration.
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# WFP_DISPATCH_NAMESPACE=
# CF_ZONE_ID=
