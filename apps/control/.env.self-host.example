# =============================================================================
# Takos Control - Self-Host Environment Variables
# =============================================================================
# Copy this file to .env.self-host or export values before starting:
#   pnpm -C apps/control dev:self-host:web
#   pnpm -C apps/control dev:self-host:dispatch
#   pnpm -C apps/control dev:self-host:runtime-host
#   pnpm -C apps/control dev:self-host:executor-host
#   pnpm -C apps/control dev:self-host:browser-host
#
# Cloudflare credentials remain optional and are only needed for Cloudflare deploy
# flows. The built-in self-host adapter stores state under TAKOS_SELF_HOST_DATA_DIR.
# =============================================================================

ADMIN_DOMAIN=admin.localhost
TENANT_BASE_DOMAIN=app.localhost
PORT=8787

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

PLATFORM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
PLATFORM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# Built-in persistence directory for the current self-host adapter.
TAKOS_SELF_HOST_DATA_DIR=/tmp/takos-control

# Internal service URLs used by the host bootstrap.
TAKOS_SELF_HOST_WEB_URL=http://127.0.0.1:8787/
TAKOS_SELF_HOST_RUNTIME_HOST_URL=http://127.0.0.1:8789/
TAKOS_SELF_HOST_EXECUTOR_HOST_URL=http://127.0.0.1:8790/
TAKOS_SELF_HOST_BROWSER_HOST_URL=http://127.0.0.1:8791/
TAKOS_SELF_HOST_RUNTIME_URL=http://127.0.0.1:8080/
TAKOS_SELF_HOST_EXECUTOR_URL=http://127.0.0.1:8080/
TAKOS_SELF_HOST_BROWSER_URL=http://127.0.0.1:8080/
#
TAKOS_OCI_ORCHESTRATOR_PORT=9002
OCI_ORCHESTRATOR_URL=http://127.0.0.1:9002/
OCI_ORCHESTRATOR_DATA_DIR=/var/lib/takos/control/oci-orchestrator
# OCI_ORCHESTRATOR_TOKEN=replace-me
CONTROL_RPC_BASE_URL=http://127.0.0.1:8790/
TAKOS_REMOTE_TOOL_EXECUTION=1
TAKOS_SELF_HOST_WORKER_POLL_INTERVAL_MS=250
TAKOS_SELF_HOST_WORKER_SCHEDULED_INTERVAL_MS=60000
TAKOS_SELF_HOST_WORKER_HEARTBEAT_FILE=/tmp/takos-control/worker-heartbeat.json
TAKOS_SELF_HOST_WORKER_HEARTBEAT_TTL_MS=120000
TAKOS_ALLOW_NO_LLM=1

# Optional routing seeds for dispatch.
# TAKOS_SELF_HOST_ROUTING_JSON={"tenant.local":"tenant-worker"}
# TAKOS_SELF_HOST_DISPATCH_TARGETS_JSON={"tenant-worker":"http://127.0.0.1:9001/"}

# Optional Cloudflare deploy target configuration.
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# WFP_DISPATCH_NAMESPACE=
# CF_ZONE_ID=
