# =============================================================================
# Takos Local-Platform Manual Template
# =============================================================================
# Use this file when you run the local-platform services individually instead of
# `deno task local:up`.
#
# Typical commands:
# - deno task --cwd apps/control dev:local:web
# - deno task --cwd apps/control dev:local:dispatch
# - deno task --cwd apps/control dev:local:worker
# - deno task --cwd apps/control dev:local:runtime-host
# - deno task --cwd apps/control dev:local:executor-host
# - deno task --cwd apps/control dev:local:browser-host
# - deno task --cwd apps/control dev:local:oci-orchestrator
#
# The env contract intentionally uses the current TAKOS_LOCAL_* naming.
# =============================================================================

TAKOS_ADMIN_DOMAIN=admin.localhost
TAKOS_TENANT_BASE_DOMAIN=app.localhost

# Port defaults: canonical source is DEFAULT_LOCAL_PORTS in
# packages/control/src/local-platform/runtime-types.ts
TAKOS_CONTROL_WEB_PORT=8787
TAKOS_CONTROL_DISPATCH_PORT=8788
TAKOS_RUNTIME_HOST_PORT=8789
TAKOS_EXECUTOR_HOST_PORT=8790
TAKOS_BROWSER_HOST_PORT=8791
TAKOS_CONTROL_WORKER_POLL_INTERVAL_MS=250
TAKOS_CONTROL_WORKER_SCHEDULED_INTERVAL_MS=60000
TAKOS_LOCAL_WORKER_HEARTBEAT_FILE=/var/lib/takos/control/worker-heartbeat.json
TAKOS_LOCAL_WORKER_HEARTBEAT_TTL_MS=120000

TAKOS_RUNTIME_PORT=8081
TAKOS_EXECUTOR_PORT=8082
TAKOS_BROWSER_PORT=8083

TAKOS_LOCAL_DATA_DIR=/var/lib/takos/control
# Infra host forwarding only. These URLs do not override tenant worker-bundle resolution.
TAKOS_LOCAL_RUNTIME_URL=http://127.0.0.1:8081/
TAKOS_LOCAL_EXECUTOR_URL=http://127.0.0.1:8082/
TAKOS_LOCAL_BROWSER_URL=http://127.0.0.1:8083/
TAKOS_LOCAL_RUNTIME_HOST_URL=http://127.0.0.1:8789
TAKOS_LOCAL_EXECUTOR_HOST_URL=http://127.0.0.1:8790
TAKOS_LOCAL_BROWSER_HOST_URL=http://127.0.0.1:8791
TAKOS_LOCAL_WEB_PUBLIC_URL=http://127.0.0.1:8787
TAKOS_LOCAL_DISPATCH_PUBLIC_URL=http://127.0.0.1:8788
TAKOS_LOCAL_RUNTIME_PUBLIC_URL=http://127.0.0.1:8081
TAKOS_LOCAL_EXECUTOR_PUBLIC_URL=http://127.0.0.1:8082
TAKOS_LOCAL_BROWSER_PUBLIC_URL=http://127.0.0.1:8083

TAKOS_OCI_ORCHESTRATOR_PORT=9002
OCI_ORCHESTRATOR_URL=http://127.0.0.1:9002/
OCI_ORCHESTRATOR_DATA_DIR=/var/lib/takos/control/oci-orchestrator
# OCI_ORCHESTRATOR_TOKEN=replace-me

CONTROL_RPC_BASE_URL=http://127.0.0.1:8790/
PROXY_BASE_URL=http://127.0.0.1:8789/

DATABASE_URL=postgresql://takos:takos@127.0.0.1:5432/takos
REDIS_URL=redis://127.0.0.1:6379
TAKOS_ALLOW_NO_LLM=1

PLATFORM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
PLATFORM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# Optional Cloudflare deploy target configuration.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# Deprecated aliases (still supported as fallback): CF_ACCOUNT_ID, CF_API_TOKEN
# WFP_DISPATCH_NAMESPACE=
# CF_ZONE_ID=
