generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model AccountBlock {
  blockerAccountId  String  @map("blocker_account_id")
  blockedAccountId  String  @map("blocked_account_id")
  createdAt  DateTime  @default(now())  @map("created_at")

  @@id([blockerAccountId, blockedAccountId])
  @@index([blockerAccountId])
  @@index([blockedAccountId])
  @@map("account_blocks")
}

model AccountEnvVar {
  id  String  @id
  accountId  String  @map("account_id")
  name  String
  valueEncrypted  String  @map("value_encrypted")
  isSecret  Boolean  @default(false)  @map("is_secret")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name])
  @@index([accountId])
  @@map("account_env_vars")
}

model AccountFollowRequest {
  id  String  @id
  requesterAccountId  String  @map("requester_account_id")
  targetAccountId  String  @map("target_account_id")
  status  String  @default("pending")
  createdAt  DateTime  @default(now())  @map("created_at")
  respondedAt  DateTime?  @map("responded_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  targetAccount  Account  @relation("AccountFollowRequestTarget", fields: [targetAccountId], references: [id], onDelete: Cascade)
  requesterAccount  Account  @relation("AccountFollowRequestRequester", fields: [requesterAccountId], references: [id], onDelete: Cascade)

  @@unique([requesterAccountId, targetAccountId])
  @@index([targetAccountId, status])
  @@index([requesterAccountId])
  @@index([createdAt])
  @@map("account_follow_requests")
}

model AccountFollow {
  followerAccountId  String  @map("follower_account_id")
  followingAccountId  String  @map("following_account_id")
  createdAt  DateTime  @default(now())  @map("created_at")
  followingAccount  Account  @relation("AccountFollowFollowing", fields: [followingAccountId], references: [id], onDelete: Cascade)
  followerAccount  Account  @relation("AccountFollowFollower", fields: [followerAccountId], references: [id], onDelete: Cascade)

  @@id([followerAccountId, followingAccountId])
  @@index([followingAccountId])
  @@index([followerAccountId])
  @@map("account_follows")
}

model AccountMembership {
  id  String  @id
  accountId  String  @map("account_id")
  memberId  String  @map("member_id")
  role  String  @default("viewer")
  status  String  @default("active")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  createdAt  DateTime  @default(now())  @map("created_at")
  memberAccount  Account  @relation("AccountMembershipMember", fields: [memberId], references: [id], onDelete: Cascade)
  account  Account  @relation("AccountMembershipAccount", fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, memberId])
  @@index([memberId])
  @@index([accountId])
  @@map("account_memberships")
}

model AccountMetadata {
  accountId  String  @map("account_id")
  key  String
  value  String
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([accountId, key])
  @@index([key])
  @@map("account_metadata")
}

model AccountModeration {
  accountId  String  @id  @map("account_id")
  status  String  @default("active")
  suspendedUntil  DateTime?  @map("suspended_until")
  warnCount  Int  @default(0)  @map("warn_count")
  lastWarnAt  DateTime?  @map("last_warn_at")
  bannedAt  DateTime?  @map("banned_at")
  reason  String?
  updatedAt  DateTime  @default(now())  @map("updated_at")
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([suspendedUntil])
  @@index([status])
  @@map("account_moderation")
}

model AccountMute {
  muterAccountId  String  @map("muter_account_id")
  mutedAccountId  String  @map("muted_account_id")
  createdAt  DateTime  @default(now())  @map("created_at")

  @@id([muterAccountId, mutedAccountId])
  @@index([muterAccountId])
  @@index([mutedAccountId])
  @@map("account_mutes")
}

model AccountSettings {
  accountId  String  @id  @map("account_id")
  setupCompleted  Boolean  @default(false)  @map("setup_completed")
  autoUpdateEnabled  Boolean  @default(true)  @map("auto_update_enabled")
  privateAccount  Boolean  @default(false)  @map("private_account")
  activityVisibility  String  @default("public")  @map("activity_visibility")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  @@map("account_settings")
}

model AccountStats {
  accountId  String  @id  @map("account_id")
  fileCount  Int  @default(0)  @map("file_count")
  totalSizeBytes  Int  @default(0)  @map("total_size_bytes")
  snapshotCount  Int  @default(0)  @map("snapshot_count")
  blobCount  Int  @default(0)  @map("blob_count")
  lastCalculatedAt  DateTime  @default(now())  @map("last_calculated_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([totalSizeBytes])
  @@index([fileCount])
  @@map("account_stats")
}

model AccountStorageFile {
  id  String  @id
  accountId  String  @map("account_id")
  parentId  String?  @map("parent_id")
  name  String
  path  String
  type  String
  size  Int  @default(0)
  mimeType  String?  @map("mime_type")
  r2Key  String?  @map("r2_key")
  sha256  String?
  uploadedByAccountId  String?  @map("uploaded_by_account_id")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  uploadedByAccount  Account?  @relation("AccountStorageFileUploader", fields: [uploadedByAccountId], references: [id])
  parent  AccountStorageFile?  @relation("StorageFileHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  AccountStorageFile[]  @relation("StorageFileHierarchy")
  account  Account  @relation("AccountStorageFileOwner", fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, path])
  @@index([path])
  @@index([parentId])
  @@index([accountId, type])
  @@index([accountId, parentId, type])
  @@index([accountId])
  @@map("account_storage_files")
}

model Account {
  id  String  @id
  type  String
  status  String  @default("active")
  name  String
  slug  String  @unique
  description  String?
  picture  String?
  bio  String?
  email  String?  @unique
  passwordHash  String?  @map("password_hash")
  googleSub  String?  @unique  @map("google_sub")
  takosAuthId  String?  @map("takos_auth_id")
  emailVerified  Boolean  @default(false)  @map("email_verified")
  setupCompleted  Boolean  @default(false)  @map("setup_completed")
  defaultRepositoryId  String?  @map("default_repository_id")
  headSnapshotId  String?  @map("head_snapshot_id")
  aiModel  String?  @default("gpt-5-mini")  @map("ai_model")
  aiProvider  String?  @default("openai")  @map("ai_provider")
  ownerAccountId  String?  @map("owner_account_id")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  accountEnvVars  AccountEnvVar[]
  receivedFollowRequests  AccountFollowRequest[]  @relation("AccountFollowRequestTarget")
  sentFollowRequests  AccountFollowRequest[]  @relation("AccountFollowRequestRequester")
  following  AccountFollow[]  @relation("AccountFollowFollowing")
  followers  AccountFollow[]  @relation("AccountFollowFollower")
  memberMemberships  AccountMembership[]  @relation("AccountMembershipMember")
  accountMemberships  AccountMembership[]  @relation("AccountMembershipAccount")
  accountMetadata  AccountMetadata[]
  accountModeration  AccountModeration?
  accountSettings  AccountSettings?
  accountStats  AccountStats?
  uploadedStorageFiles  AccountStorageFile[]  @relation("AccountStorageFileUploader")
  storageFiles  AccountStorageFile[]  @relation("AccountStorageFileOwner")
  ownerAccount  Account?  @relation("AccountOwnership", fields: [ownerAccountId], references: [id])
  ownedAccounts  Account[]  @relation("AccountOwnership")
  createdAgentTasks  AgentTask[]  @relation("AgentTaskCreator")
  agentTasks  AgentTask[]  @relation("AgentTaskOwner")
  apps  App[]
  artifacts  Artifact[]
  authSessions  AuthSession[]
  billingAccounts  BillingAccount?
  blobs  Blob[]
  deployedBundleDeploymentEvents  BundleDeploymentEvent[]  @relation("BundleDeploymentEventDeployer")
  bundleDeploymentEvents  BundleDeploymentEvent[]  @relation("BundleDeploymentEventOwner")
  lockedBundleDeployments  BundleDeployment[]  @relation("BundleDeploymentLocker")
  deployedBundleDeployments  BundleDeployment[]  @relation("BundleDeploymentDeployer")
  bundleDeployments  BundleDeployment[]  @relation("BundleDeploymentOwner")
  chunks  Chunk[]
  actorCommonEnvAuditLogs  CommonEnvAuditLog[]  @relation("CommonEnvAuditActor")
  commonEnvAuditLogs  CommonEnvAuditLog[]  @relation("CommonEnvAuditOwner")
  commonEnvReconcileJobs  CommonEnvReconcileJob[]
  deploymentEvents  DeploymentEvent[]
  deployments  Deployment[]
  edges  Edge[]
  fileHandlers  FileHandler[]
  files  File[]
  authoredGitCommits  GitCommit[]  @relation("GitCommitAuthor")
  gitCommits  GitCommit[]  @relation("GitCommitOwner")
  indexJobs  IndexJob[]
  infoUnits  InfoUnit[]
  infraEndpoints  InfraEndpoint[]
  serviceRuntimes  ServiceRuntime[]
  subjectManagedTakosTokens  ManagedTakosToken[]  @relation("ManagedTakosTokenSubject")
  managedTakosTokens  ManagedTakosToken[]  @relation("ManagedTakosTokenOwner")
  mcpOauthPending  McpOAuthPending[]
  mcpServers  McpServer[]
  authoredMemories  Memory[]  @relation("MemoryAuthor")
  memories  Memory[]  @relation("MemoryOwner")
  moderationAuditLogs  ModerationAuditLog[]
  nodes  Node[]
  notificationPreferences  NotificationPreference[]
  notificationSettings  NotificationSettings?
  actorNotifications  Notification[]  @relation("NotificationActor")
  notifications  Notification[]  @relation("NotificationRecipient")
  oauthAuditLogs  OAuthAuditLog[]
  oauthClients  OAuthClient[]
  oauthConnections  OAuthConnection[]
  oauthConsents  OAuthConsent[]
  oauthDeviceCodes  OAuthDeviceCode[]
  oauthTokens  OAuthToken[]
  personalAccessTokens  PersonalAccessToken[]
  ownerReminders  Reminder[]  @relation("ReminderOwner")
  reminders  Reminder[]  @relation("ReminderAccount")
  repoReleases  RepoRelease[]
  repoStars  RepoStar[]
  reports  Report[]
  repositories  Repository[]
  grantedResourceAccess  ResourceAccess[]  @relation("ResourceAccessGranter")
  resourceAccess  ResourceAccess[]  @relation("ResourceAccessAccount")
  accountResources  Resource[]  @relation("ResourceAccount")
  ownedResources  Resource[]  @relation("ResourceOwner")
  runs  Run[]
  serviceTokens  ServiceToken[]
  userSessions  Session[]  @relation("SessionUser")
  sessions  Session[]  @relation("SessionOwner")
  shortcutGroups  ShortcutGroup[]
  accountShortcuts  Shortcut[]  @relation("ShortcutAccount")
  userShortcuts  Shortcut[]  @relation("ShortcutUser")
  skills  Skill[]
  snapshots  Snapshot[]
  createdThreadShares  ThreadShare[]  @relation("ThreadShareCreator")
  threadShares  ThreadShare[]  @relation("ThreadShareOwner")
  threads  Thread[]
  uiExtensions  UIExtension[]
  usageEvents  UsageEvent[]
  usageRollups  UsageRollup[]
  serviceCommonEnvLinks  ServiceCommonEnvLink[]
  serviceRuntimeSettings  ServiceRuntimeSetting[]
  services  Service[]
  workflowRuns  WorkflowRun[]

  @@index([type])
  @@index([takosAuthId])
  @@index([slug])
  @@index([ownerAccountId])
  @@index([googleSub])
  @@index([email])
  @@index([defaultRepositoryId])
  @@map("accounts")
}

model AgentTask {
  id  String  @id
  accountId  String  @map("account_id")
  createdByAccountId  String?  @map("created_by_account_id")
  threadId  String?  @map("thread_id")
  lastRunId  String?  @map("last_run_id")
  title  String
  description  String?
  status  String  @default("planned")
  priority  String  @default("medium")
  agentType  String  @default("default")  @map("agent_type")
  model  String?
  plan  String?
  dueAt  DateTime?  @map("due_at")
  startedAt  DateTime?  @map("started_at")
  completedAt  DateTime?  @map("completed_at")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  run  Run?  @relation(fields: [lastRunId], references: [id])
  thread  Thread?  @relation(fields: [threadId], references: [id])
  createdByAccount  Account?  @relation("AgentTaskCreator", fields: [createdByAccountId], references: [id])
  account  Account  @relation("AgentTaskOwner", fields: [accountId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([status])
  @@index([priority])
  @@index([lastRunId])
  @@index([createdByAccountId])
  @@index([accountId, status])
  @@index([accountId])
  @@index([accountId, createdAt])
  @@map("agent_tasks")
}

model App {
  id  String  @id
  accountId  String  @map("account_id")
  serviceId  String?  @map("service_id")
  name  String
  description  String?
  icon  String?
  appType  String  @map("app_type")
  takosClientKey  String?  @map("takos_client_key")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  service  Service?  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([appType])
  @@index([accountId])
  @@map("apps")
}

model Artifact {
  id  String  @id
  runId  String  @map("run_id")
  accountId  String  @map("account_id")
  type  String  @default("code")
  title  String?
  content  String?
  fileId  String?  @map("file_id")
  metadata  String  @default("{}")
  createdAt  DateTime  @default(now())  @map("created_at")
  file  File?  @relation(fields: [fileId], references: [id])
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  run  Run  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([runId])
  @@index([fileId])
  @@index([accountId])
  @@map("artifacts")
}

model AuthService {
  id  String  @id
  name  String
  domain  String  @unique
  apiKeyHash  String  @map("api_key_hash")
  allowedRedirectUris  String?  @map("allowed_redirect_uris")
  createdAt  DateTime  @default(now())  @map("created_at")

  @@index([domain])
  @@index([apiKeyHash])
  @@map("auth_services")
}

model AuthSession {
  id  String  @id
  accountId  String  @map("account_id")
  tokenHash  String  @unique  @map("token_hash")
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now())  @map("created_at")
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([expiresAt])
  @@index([accountId])
  @@map("auth_sessions")
}

model BillingAccount {
  id  String  @id
  accountId  String  @unique  @map("account_id")
  planId  String  @map("plan_id")
  balanceCents  Int  @default(0)  @map("balance_cents")
  status  String  @default("active")
  stripeCustomerId  String?  @map("stripe_customer_id")
  stripeSubscriptionId  String?  @map("stripe_subscription_id")
  subscriptionStartedAt  String?  @map("subscription_started_at")
  subscriptionPeriodEnd  String?  @map("subscription_period_end")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  billingPlan  BillingPlan  @relation(fields: [planId], references: [id])
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  billingTransactions  BillingTransaction[]
  usageEvents  UsageEvent[]
  usageRollups  UsageRollup[]

  @@index([stripeCustomerId])
  @@index([status])
  @@index([planId])
  @@index([accountId])
  @@map("billing_accounts")
}

model BillingPlanFeature {
  planId  String  @map("plan_id")
  featureKey  String  @map("feature_key")
  enabled  Boolean  @default(false)
  billingPlan  BillingPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([planId, featureKey])
  @@map("billing_plan_features")
}

model BillingPlanQuota {
  planId  String  @map("plan_id")
  quotaKey  String  @map("quota_key")
  limitValue  Int  @map("limit_value")
  billingPlan  BillingPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([planId, quotaKey])
  @@map("billing_plan_quotas")
}

model BillingPlanRate {
  planId  String  @map("plan_id")
  meterType  String  @map("meter_type")
  rateCents  Int  @map("rate_cents")
  billingPlan  BillingPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([planId, meterType])
  @@map("billing_plan_rates")
}

model BillingPlan {
  id  String  @id
  name  String  @unique
  displayName  String  @map("display_name")
  description  String?
  isDefault  Boolean  @default(false)  @map("is_default")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  billingAccounts  BillingAccount[]
  billingPlanFeatures  BillingPlanFeature[]
  billingPlanQuotas  BillingPlanQuota[]
  billingPlanRates  BillingPlanRate[]

  @@index([name])
  @@index([isDefault])
  @@map("billing_plans")
}

model BillingTransaction {
  id  String  @id
  billingAccountId  String  @map("billing_account_id")
  type  String
  amountCents  Int  @map("amount_cents")
  balanceAfterCents  Int  @map("balance_after_cents")
  description  String?
  referenceId  String?  @map("reference_id")
  metadata  String  @default("{}")
  createdAt  DateTime  @default(now())  @map("created_at")
  billingAccount  BillingAccount  @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([referenceId])
  @@index([createdAt])
  @@index([billingAccountId])
  @@map("billing_transactions")
}

model Blob {
  accountId  String  @map("account_id")
  hash  String
  size  Int
  isBinary  Boolean  @default(false)  @map("is_binary")
  refcount  Int  @default(1)
  createdAt  DateTime  @default(now())  @map("created_at")
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([accountId, hash])
  @@index([refcount])
  @@map("blobs")
}

model Branch {
  id  String  @id
  repoId  String  @map("repo_id")
  name  String
  commitSha  String  @map("commit_sha")
  isDefault  Boolean  @default(false)  @map("is_default")
  isProtected  Boolean  @default(false)  @map("is_protected")
  createdAt  DateTime  @default(now())  @map("created_at")
  updatedAt  DateTime  @default(now())  @map("updated_at")
  repository  Repository  @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, name])
  @@index([repoId])
  @@index([commitSha])
  @@map("branches")
}

model BundleDeploymentEvent {
  id  String  @id
  accountId  String  @map("account_id")
  bundleDeploymentId  String?  @map("bundle_deployment_id")
  name  String
  appId  String  @map("app_id")
  bundleKey  String  @map("bundle_key")
  version  String
  deployAction  String  @map("deploy_action")
  deployedAt  DateTime  @default(now())  @map("deployed_at")
  deployedByAccountId  String  @map("deployed_by_account_id")
  sourceType  String?  @map("source_type")
  sourceRepoId  String?  @map("source_repo_id")
  sourceTag  String?  @map("source_tag")
  sourceAssetId  String?  @map("source_asset_id")
  replacedBundleDeploymentId  String?  @map("replaced_bundle_deployment_id")
  replacedDeployment  BundleDeployment?  @relation("BundleDeploymentReplacingEvents", fields: [replacedBundleDeploymentId], references: [id])
  deployedByAccount  Account  @relation("BundleDeploymentEventDeployer", fields: [deployedByAccountId], references: [id])
  bundleDeployment  BundleDeployment?  @relation("BundleDeploymentEvents", fields: [bundleDeploymentId], references: [id])
  account  Account  @relation("BundleDeploymentEventOwner", fields: [accountId], references: [id], onDelete: Cascade)

  @@index([sourceRepoId])
  @@index([bundleKey])
  @@index([bundleDeploymentId])
  @@index([accountId, name, deployedAt])
  @@index([accountId])
  @@map("bundle_deployment_events")
}

model BundleDeployment {
  id  String  @id
  accountId  String  @map("account_id")
  name  String
  appId  String  @map("app_id")
  bundleKey  String  @map("bundle_key")
  version  String
  versionMajor  Int  @default(0)  @map("version_major")
  versionMinor  Int  @default(0)  @map("version_minor")
  versionPatch  Int  @default(0)  @map("version_patch")
  description  String?
  icon  String?
  manifestJson  String  @map("manifest_json")
  deployedAt  DateTime  @default(now())  @map("deployed_at")
  deployedByAccountId  String  @map("deployed_by_account_id")
  sourceType  String?  @map("source_type")
  sourceRepoId  String?  @map("source_repo_id")
  sourceTag  String?  @map("source_tag")
  sourceAssetId  String?  @map("source_asset_id")
  oauthClientId  String?  @map("oauth_client_id")
  isLocked  Boolean  @default(false)  @map("is_locked")
  lockedAt  DateTime?  @map("locked_at")
  lockedByAccountId  String?  @map("locked_by_account_id")
  replacingEvents  BundleDeploymentEvent[]  @relation("BundleDeploymentReplacingEvents")
  deploymentEvents  BundleDeploymentEvent[]  @relation("BundleDeploymentEvents")
  lockedByAccount  Account?  @relation("BundleDeploymentLocker", fields: [lockedByAccountId], references: [id])
  deployedByAccount  Account  @relation("BundleDeploymentDeployer", fields: [deployedByAccountId], references: [id])
  account  Account  @relation("BundleDeploymentOwner", fields: [accountId], references: [id], onDelete: Cascade)
  fileHandlers  FileHandler[]
  infraEndpoints  InfraEndpoint[]
  serviceRuntimes  ServiceRuntime[]
  mcpServers  McpServer[]
  shortcutGroups  ShortcutGroup[]
  uiExtensions  UIExtension[]

  @@unique([accountId, name])
  @@unique([accountId, appId])
  @@index([sourceRepoId])
  @@index([bundleKey])
  @@index([accountId])
  @@map("bundle_deployments")
}

model Chunk {
  id  String  @id
  fileId  String  @map("file_id")
  accountId  String  @map("account_id")
  startLine  Int  @map("start_line")
  endLine  Int  @map("end_line")
  content  String
  vectorId  String?  @map("vector_id")
  createdAt  DateTime  @default(now())  @map("created_at")
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  file  File  @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([vectorId])
  @@index([fileId])
  @@index([accountId])
  @@map("chunks")
}

model Commit {
  id  String  @id
  repoId  String  @map("repo_id")
  sha  String
  treeSha  String  @map("tree_sha")
  parentShas  String?  @map("parent_shas")
  authorName  String  @map("author_name")
  authorEmail  String  @map("author_email")
  authorDate  DateTime  @map("author_date")
  committerName  String  @map("committer_name")
  committerEmail  String  @map("committer_email")
  commitDate  DateTime  @map("commit_date")
  message  String
  repository  Repository  @relation(fields: [repoId], references: [id], onDelete: Cascade)

