    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.11.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260118.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "wrangler": "^4.61.0"
  }
}
