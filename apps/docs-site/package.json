{
  "name": "@takos/takos-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/backend/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:node": "tsx watch src/backend/server-node.ts",
