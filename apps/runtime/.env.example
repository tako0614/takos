# =============================================================================
# Takos Runtime - Environment Variables
# =============================================================================
# This file documents all environment variables used by takos-runtime.
# Copy this file to .env for local development.
#
# The runtime service handles sandboxed code execution for the AI agent,
# and can run either in Cloudflare Containers or as a server Node service.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8080
NODE_ENV=development

# -----------------------------------------------------------------------------
# Object Storage Credentials (Required)
# Local runtime uses generic S3-compatible settings.
# Cloudflare R2 remains available through the compatibility aliases below.
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=takos
S3_SECRET_ACCESS_KEY=takos-dev-secret
S3_BUCKET=takos-tenant-source

# Cloudflare R2 compatibility aliases (optional)
# If S3_* is unset, runtime falls back to these values.
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET=takos-tenant-source

# -----------------------------------------------------------------------------
# Takos API Configuration (Required)
# URL of the main takos-control service
# Port 8787 = DEFAULT_LOCAL_PORTS.web in
# packages/control/src/local-platform/runtime-types.ts
# -----------------------------------------------------------------------------
TAKOS_API_URL=http://127.0.0.1:8787

# -----------------------------------------------------------------------------
# JWT Public Key (Optional but Recommended)
# RS256 public key for verifying service-to-service JWT tokens
# Multi-line PEM can be passed with literal \n characters
# Example: JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjAN..."
# -----------------------------------------------------------------------------
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjAN...\n-----END PUBLIC KEY-----

# -----------------------------------------------------------------------------
# Git Remote Tokens (Optional)
# For git remote operations when cloning/pushing via URL token
# -----------------------------------------------------------------------------
# TAKOS_TOKEN=your-takos-token
# Git Endpoint (Optional)
# Primary endpoint is used to construct repository URLs for Actions checkout.
# -----------------------------------------------------------------------------
GIT_ENDPOINT_URL=https://git.takos.dev

# =============================================================================
# Built-in Limits (Reference - configured in config.ts)
# =============================================================================
# These are not environment variables but are documented here for reference:
#
# MAX_LOG_LINES=100000
# HEARTBEAT_INTERVAL_MS=30000
#
# Execution limits:
# MAX_EXEC_COMMANDS=50
# MAX_EXEC_FILES=1000
# MAX_EXEC_FILE_BYTES=10MB
# MAX_EXEC_TOTAL_BYTES=100MB
# MAX_EXEC_OUTPUTS=50
# MAX_EXEC_OUTPUT_BYTES=5MB
# MAX_EXEC_OUTPUT_TOTAL_BYTES=20MB
# MAX_SESSION_FILE_READ_BYTES=50MB
#
# Object storage download limits (DoS protection):
# MAX_R2_DOWNLOAD_FILE_BYTES=500MB
# MAX_R2_DOWNLOAD_TOTAL_BYTES=2GB
#
# Allowed commands: npm, npx, node, echo, ls, cat, pwd, mkdir, cp, mv, rm,
#                   git, esbuild, wrangler, curl, wget, tar, unzip, takos
# =============================================================================
