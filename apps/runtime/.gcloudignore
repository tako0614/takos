# Cloud Build ignore file
# Note: We explicitly include takos-cli/ (unlike .gitignore)

# Node modules (will be installed during build)
node_modules/
takos-cli/node_modules/

# Development files
*.log
.env
.env.*

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
