{
  "name": "@takos/runtime",
  "version": "1.0.0",
  "description": "Runtime environment for Takos agent command execution",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "takos": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "pnpm -C ../.. --filter @takos/runtime-service build && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "cli": "node dist/cli/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@takos/actions-engine": "workspace:*",
    "@takos/common": "workspace:*",
    "@takos/runtime-service": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
