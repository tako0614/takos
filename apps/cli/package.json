{
  "name": "takos-cli",
  "version": "0.1.1",
  "description": "CLI tool for Takos AI platform - deploy, manage workers, and interact with cloud resources",
  "type": "module",
  "bin": {
    "takos": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "publish:jsr": "npx jsr publish"
  },
  "dependencies": {
    "takos-actions-engine": "workspace:*",
    "takos-control": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "open": "^10.1.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsup": "^8.1.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "takos",
    "cli",
    "deploy",
    "cloudflare",
    "workers",
    "ai",
    "platform",
    "d1",
    "r2",
    "kv"
  ],
  "license": "AGPL-3.0-only",
  "author": "Takos Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/takos-platform/cli.git"
  },
  "homepage": "https://takos.jp",
  "bugs": {
    "url": "https://github.com/takos-platform/cli/issues"
  }
}
