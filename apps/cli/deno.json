{
  "name": "takos-cli",
  "version": "0.1.1",
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt/colors": "jsr:@std/fmt@^1/colors",
    "@std/testing/mock": "jsr:@std/testing@^1.0.17/mock",
    "commander": "npm:commander@^12.1.0",
    "ws": "npm:ws@^8.19.0",
    "yaml": "npm:yaml@^2.8.2"
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any",
        "no-import-prefix",
        "no-process-global",
        "no-unversioned-import",
        "no-unsafe-finally",
        "require-await"
      ]
    }
  },
  "tasks": {
    "dev": "deno run --allow-all --watch src/index.ts",
    "start": "deno run --allow-all src/index.ts",
    "test": "deno test --allow-all src/",
    "test:coverage": "deno test --allow-all --coverage src/",
    "compile": "deno compile --allow-all --output takos src/index.ts",
    "publish:jsr": "deno publish"
  },
  "publish": {
    "include": ["src/", "deno.json", "LICENSE", "README.md"]
  }
}
